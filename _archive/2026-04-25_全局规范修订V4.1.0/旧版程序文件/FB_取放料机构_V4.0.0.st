﻿//==============================================================================
// 边框缓存机 PLC程序 - 取放料机构纯逻辑功能块
// 版本: V4.0.0
// 项目: DJ-2026-005 边框缓存机
// 编制日期: 2026-04-23
// 遵循规范: IEC 61131-3, 810_PLC编程规范_DEV-V1.0.0
// 说明: 纯逻辑功能块 - 取放料机构独立控制(不包含任何X/Y/M/D地址引用)
//       所有输入来自主控(已映射的逻辑变量), 所有输出给主控(由主控映射到Y地址)
//
// 核心工艺:
//   一次取两根边框(前后夹紧同时动作), 4层总共循环取2次
//   取料顺序: 第1次取L1+L2层, 第2次取L3+L4层
//   每次取料后移动到放料位置, 完成放料后通知下游(打胶机送料机构)
//
// 架构特点:
//   - 纯逻辑块: 不包含任何X/Y/M/D地址引用
//   - 数据解耦: 通过逻辑变量接口与主控交互
//   - 11步状态机: 完整的自动取放料循环控制
//   - 故障安全: 内置超时保护、伺服故障检测、传感器冲突检测
//   - 4层循环: 自动管理4层取放料进度, 循环2次完成全部取料
//==============================================================================

//==============================================================================
// 功能块: FB_取放料机构 - 取放料机构纯逻辑控制
// 功能:
//   1. 自动模式状态机(11步完整取放料循环)
//   2. 手动模式控制(14个手动操作信号)
//   3. 初始化流程(气缸复位、伺服使能、状态清零)
//   4. 块内报警检测与处理(8种报警类型, 101~199段)
//   5. 4层循环计数器(一次取两层, 循环2次取完4层)
//   6. 完全自包含, 无外部物理地址依赖
//==============================================================================
FUNCTION_BLOCK FB_1003_PickPlace_BufferFraming

VAR_INPUT
    (*==========================================================================
      一、系统控制信号 (来自主控/HMI M区)
      ==========================================================================*)
    i_b使能               : BOOL;    // 总使能信号(主控系统就绪后置位)

    (*-------------------------------------------------------------------------
      模式选择 (互斥信号,来自HMI M区)
      -------------------------------------------------------------------------*)
    i_b自动模式           : BOOL;    // 自动运行模式选择
    i_b手动模式           : BOOL;    // 手动调试模式选择

    (*-------------------------------------------------------------------------
      操作按钮 (来自HMI,边沿触发或电平有效)
      -------------------------------------------------------------------------*)
    i_b启动               : BOOL;    // 自动循环启动按钮(上升沿触发)
    i_b停止               : BOOL;    // 自动循环停止按钮(电平有效)
    i_b复位               : BOOL;    // 故障复位/初始化按钮(电平有效)

    (*==========================================================================
      二、手动操作信号 (14个BOOL,来自HMI)
      ==========================================================================*)
    (*--- 伺服点动控制 (4个) ---*)
    i_bZ轴点动上          : BOOL;    // 手动-Z轴向上点动
    i_bZ轴点动下          : BOOL;    // 手动-Z轴向下点动
    i_bX1轴点动前         : BOOL;    // 手动-X1轴向前点动(取料方向)
    i_bX1轴点动后         : BOOL;    // 手动-X1轴向后点动(放料方向)

    (*--- 气缸手动控制 (10个) ---*)
    (* 升降气缸: 双电磁阀控制 *)
    i_b升降上升           : BOOL;    // 手动-升降气缸上升
    i_b升降下降           : BOOL;    // 手动-升降气缸下降

    (* 前夹紧气缸: 双电磁阀控制(夹紧/松开) *)
    i_b前夹紧夹紧         : BOOL;    // 手动-前夹紧气缸夹紧
    i_b前夹紧松开         : BOOL;    // 手动-前夹紧气缸松开

    (* 后夹紧气缸: 双电磁阀控制(夹紧/松开) *)
    i_b后夹紧夹紧         : BOOL;    // 手动-后夹紧气缸夹紧
    i_b后夹紧松开         : BOOL;    // 手动-后夹紧气缸松开

    (* 前夹紧2气缸: 双电磁阀控制(夹紧/松开) - 第二组前夹爪 *)
    i_b前夹紧2夹紧        : BOOL;    // 手动-前夹紧2气缸夹紧
    i_b前夹紧2松开        : BOOL;    // 手动-前夹紧2气缸松开

    (* 后夹紧2气缸: 双电磁阀控制(夹紧/松开) - 第二组后夹爪 *)
    i_b后夹紧2夹紧        : BOOL;    // 手动-后夹紧2气缸夹紧
    i_b后夹紧2松开        : BOOL;    // 手动-后夹紧2气缸松开

    (*==========================================================================
      三、工艺参数 (来自HMI设定或配方)
      ==========================================================================*)
    (*--- 运动速度参数 (REAL) ---*)
    i_r取料速度           : REAL;    // 取料过程Z轴下降/上升速度(mm/s或%)
    i_r放料速度           : REAL;    // 放料过程Z轴下降/上升速度(mm/s或%)
    i_rZ轴速度            : REAL;    // Z轴通用运动速度设定(mm/s)
    i_rX1轴速度           : REAL;    // X1轴通用运动速度设定(mm/s)

    (*--- 动作时间参数 (INT, 单位: ms) ---*)
    i_i夹紧确认时间       : INT;     // 夹爪夹紧确认等待时间(ms)
    i_i升降动作时间       : INT;     // 升降气缸动作超时时间(ms)

    (*==========================================================================
      四、传感器输入 (26个BOOL,全部来自主控IO映射)
      注: 本功能块不直接读取X地址, 所有传感器由主控映射后传入
      ==========================================================================*)

    (*--- 气缸位置传感器 (10个磁性开关) ---*)
    (* 升降气缸: 动点=下降到位, 原点=上升到位 *)
    i_b升降_动点           : BOOL;    // 升降气缸下降到位(动点)
    i_b升降_原点           : BOOL;    // 升降气缸上升到位(原点)

    (* 前夹紧气缸: 动点=夹紧到位, 原点=松开到位 *)
    i_b前夹紧_动点         : BOOL;    // 前夹紧气缸夹紧到位(动点)
    i_b前夹紧_原点         : BOOL;    // 前夹紧气缸松开到位(原点)

    (* 后夹紧气缸: 动点=夹紧到位, 原点=松开到位 *)
    i_b后夹紧_动点         : BOOL;    // 后夹紧气缸夹紧到位(动点)
    i_b后夹紧_原点         : BOOL;    // 后夹紧气缸松开到位(原点)

    (* 前夹紧2气缸: 第二组前夹爪 *)
    i_b前夹紧2_动点        : BOOL;    // 前夹紧2气缸夹紧到位(动点)
    i_b前夹紧2_原点        : BOOL;    // 前夹紧2气缸松开到位(原点)

    (* 后夹紧2气缸: 第二组后夹爪 *)
    i_b后夹紧2_动点        : BOOL;    // 后夹紧2气缸夹紧到位(动点)
    i_b后夹紧2_原点        : BOOL;    // 后夹紧2气缸松开到位(原点)

    (*--- 产品检测传感器 (4个光电传感器) ---*)
    (* 一次取两根边框: 长边×2 + 短边×2 *)
    i_b长边1检测           : BOOL;    // 长边1存在检测(光电传感器)
    i_b长边2检测           : BOOL;    // 长边2存在检测(光电传感器)
    i_b短边1检测           : BOOL;    // 短边1存在检测(光电传感器)
    i_b短边2检测           : BOOL;    // 短边2存在检测(光电传感器)

    (*--- 伺服轴状态信号 (12个, 来自驱动器和限位开关) ---*)
    (* 原点信号 *)
    i_bZ轴_原点            : BOOL;    // Z轴伺服原点信号
    i_bX1轴_原点           : BOOL;    // X1轴伺服原点信号
    i_bX2轴_原点           : BOOL;    // X2轴伺服原点信号(预留)

    (* 伺服故障报警 *)
    i_bZ轴_伺服故障        : BOOL;    // Z轴伺服驱动器故障(ALM输出)
    i_bX1轴_伺服故障       : BOOL;    // X1轴伺服驱动器故障(ALM输出)
    i_bX2轴_伺服故障       : BOOL;    // X2轴伺服驱动器故障(预留)

    (* 限位开关信号 *)
    i_bZ轴_正向限位        : BOOL;    // Z轴正向限位(上限位)
    i_bZ轴_反向限位        : BOOL;    // Z轴反向限位(下限位)
    i_bX1轴_正向限位       : BOOL;    // X1轴正向限位(取料侧限位)
    i_bX1轴_反向限位       : BOOL;    // X1轴反向限位(放料侧限位)
    i_bX2轴_正向限位       : BOOL;    // X2轴正向限位(预留)
    i_bX2轴_反向限位       : BOOL;    // X2轴反向限位(预留)

    (*==========================================================================
      五、上游信号 (来自四层输送机的放料完成信号)
      ==========================================================================*)
    i_b输送机_L1_放料完成  : BOOL;    // 输送机第1层放料完成
    i_b输送机_L2_放料完成  : BOOL;    // 输送机第2层放料完成
    i_b输送机_L3_放料完成  : BOOL;    // 输送机第3层放料完成
    i_b输送机_L4_放料完成  : BOOL;    // 输送机第4层放料完成
END_VAR


VAR_OUTPUT
    (*==========================================================================
      一、执行器请求输出 (给主控, 由主控映射到Y地址)
      ==========================================================================*)

    (*--- 气缸控制输出 (6个BOOL) ---*)
    (* 升降气缸: 上升/下降双电磁阀 *)
    o_b升降_上升           : BOOL;    // 升降气缸上升电磁阀 -> 主控 -> Y地址
    o_b升降_下降           : BOOL;    // 升降气缸下降电磁阀 -> 主控 -> Y地址

    (* 前夹紧气缸: 夹紧/松开双电磁阀 *)
    o_b前夹紧_夹紧         : BOOL;    // 前夹紧气缸夹紧电磁阀 -> 主控 -> Y地址
    o_b前夹紧_松开         : BOOL;    // 前夹紧气缸松开电磁阀 -> 主控 -> Y地址

    (* 后夹紧气缸: 夹紧/松开双电磁阀 *)
    o_b后夹紧_夹紧         : BOOL;    // 后夹紧气缸夹紧电磁阀 -> 主控 -> Y地址
    o_b后夹紧_松开         : BOOL;    // 后夹紧气缸松开电磁阀 -> 主控 -> Y地址

    (* 前夹紧2气缸: 夹紧/松开双电磁阀(第二组前夹爪) *)
    o_b前夹紧2_夹紧        : BOOL;    // 前夹紧2气缸夹紧电磁阀 -> 主控 -> Y地址
    o_b前夹紧2_松开        : BOOL;    // 前夹紧2气缸松开电磁阀 -> 主控 -> Y地址

    (* 后夹紧2气缸: 夹紧/松开双电磁阀(第二组后夹爪) *)
    o_b后夹紧2_夹紧        : BOOL;    // 后夹紧2气缸夹紧电磁阀 -> 主控 -> Y地址
    o_b后夹紧2_松开        : BOOL;    // 后夹紧2气缸松开电磁阀 -> 主控 -> Y地址

    (*--- 伺服控制输出 (3个BOOL, 仅Z轴由本功能块直接控制) ---*)
    (* 注: X1轴/X2轴的运动指令通过内部标志传递给主控处理脉冲输出 *)
    o_bZ轴_脉冲输出        : BOOL;    // Z轴脉冲输出使能 -> 主控 -> Y0(PULSE)
    o_bZ轴_方向输出        : BOOL;    // Z轴方向控制 -> 主控 -> Y4(SIGN)
    o_bZ轴_伺服使能        : BOOL;    // Z轴伺服励磁(SON) -> 主控 -> Y10

    (*==========================================================================
      二、下游信号输出 (给打胶机送料机构)
      ==========================================================================*)
    o_b放料完成_给送料机构 : BOOL;    // 放料完成通知下游(打胶机可取料)

    (*==========================================================================
      三、状态/HMI显示输出
      ==========================================================================*)
    o_b运行中             : BOOL;    // 本站正在自动运行
    o_b故障               : BOOL;    // 本站有故障(任一报警激活)
    o_i当前状态           : INT;     // 当前状态机步序(0~10, 99=故障)
    o_rZ轴当前位置        : REAL;    // Z轴当前位置反馈(mm, 来自主控映射)
    o_rX1轴当前位置       : REAL;    // X1轴当前位置反馈(mm, 来自主控映射)
    o_rX2轴当前位置       : REAL;    // X2轴当前位置反馈(mm, 预留, 来自主控映射)
    o_i当前取料层数       : INT;     // 当前正在处理的层数(0=空闲, 1~4=层号)

    (*==========================================================================
      四、报警输出 (给公共报警管理器)
      ==========================================================================*)
    o_i本站报警代码       : INT;     // 本站当前有效报警代码(0=无报警, 101~199=报警类型)
END_VAR


(*==============================================================================
 内部变量定义
 ==============================================================================*)
VAR
    (*--------------------------------------------------------------------------
      一、状态机核心变量
      --------------------------------------------------------------------------*)
    s_i步序               : INT;     // 当前状态机步序(0~10)
    s_b运行中             : BOOL;    // 自动运行中标志
    s_b故障               : BOOL;    // 故障标志
    s_b启动触发           : BOOL;    // 启动信号锁存(防重复触发)

    (*--- 4层循环计数器 ---*)
    s_i已完成层数         : INT;     // 已完成的取放料层数(0~4)
    s_i当前取料层号       : INT;     // 当前正在取料的层号(1~4)
    s_i取料次数           : INT;     // 当前是第几次取料(1或2)

    (*--- 放料完成通知脉冲 ---*)
    s_b放料完成脉冲       : BOOL;    // 放料完成单周期脉冲
    s_t放料完成保持定时器 : TON;     // 放料完成信号保持定时器

    (*--------------------------------------------------------------------------
      二、定时器 (覆盖所有时序需求)
      --------------------------------------------------------------------------*)
    s_t动作定时器         : TON;     // 通用动作等待定时器(升降/夹紧/松开/移动)
    s_t产品检测稳定定时器 : TON;     // 产品检测稳定等待定时器
    s_t初始化定时器       : TON;     // 初始化总超时定时器

    (*--------------------------------------------------------------------------
      三、系统级内部变量
      --------------------------------------------------------------------------*)
    s_b初始化完成         : BOOL;    // 上电初始化完成标志
    s_b初始化中           : BOOL;    // 正在执行初始化
    s_b产品检测通过       : BOOL;    // 产品检测结果(4传感器全检测到)

    (*--- 报警相关 ---*)
    s_i活跃报警           : INT;     // 当前最高优先级报警代码

    (*--- 伺服运动请求标志 (给主控处理脉冲输出) ---*)
    s_bZ轴请求下降        : BOOL;    // Z轴下降运动请求
    s_bZ轴请求上升        : BOOL;    // Z轴上升运动请求
    s_bX1轴请求前移       : BOOL;    // X1轴向前移动请求(去取料位置)
    s_bX1轴请求后移       : BOOL;    // X1轴向后移动请求(去放料位置)
    s_bX1轴在取料位       : BOOL;    // X1轴是否在取料位置标志
    s_bX1轴在放料位       : BOOL;    // X1轴是否在放料位置标志

    (*--- 传感器冲突检测 ---*)
    s_b升降冲突           : BOOL;    // 升降上下位同时为TRUE
    s_b前夹紧冲突         : BOOL;    // 前夹紧夹紧/松开同时为TRUE
    s_b后夹紧冲突         : BOOL;    // 后夹紧夹紧/松开同时为TRUE
    s_b前夹紧2冲突        : BOOL;    // 前夹紧2夹紧/松开同时为TRUE
    s_b后夹紧2冲突        : BOOL;    // 后夹紧2夹紧/松开同时为TRUE

    (*--- 手动操作互锁 ---*)
    s_b手动允许           : BOOL;    // 允许手动操作标志
END_VAR


(*==============================================================================
 常量定义 (状态机步序 + 报警码 + 定时参数)
 ==============================================================================*)
VAR CONSTANT
    (*--------------------------------------------------------------------------
      状态机步序常量 (11步: 0空闲 + 10工作步)
      核心工艺: 一次取两根边框, 4层循环取2次
      --------------------------------------------------------------------------*)
    STP_空闲              : INT := 0;   // 空闲待机
    STP_等待放料完成      : INT := 1;   // 等待输送机放料完成信号
    STP_取料下降          : INT := 2;   // Z轴下降到取料高度
    STP_夹爪夹紧          : INT := 3;   // 前后夹紧同时夹紧(一次取两根)
    STP_产品检测          : INT := 4;   // 产品检测确认(长边+短边共4传感器)
    STP_取料上升          : INT := 5;   // Z轴上升到安全高度
    STP_移动到放料位置    : INT := 6;   // X1轴移动到放料位置(打胶机侧)
    STP_放料下降          : INT := 7;   // Z轴下降到放料高度
    STP_夹爪松开          : INT := 8;   // 前后夹紧同时松开
    STP_放料上升          : INT := 9;   // Z轴上升到安全高度
    STP_放料完成通知      : INT := 10;  // 发送放料完成信号给下游

    (*--------------------------------------------------------------------------
      报警码常量 (101~199段, 0=无报警)
      与四层输送机(1~7段)、其他设备错开, 便于公共报警管理器区分来源
      --------------------------------------------------------------------------*)
    ALM_Z轴伺服故障       : INT := 101;  // Z轴伺服驱动器故障
    ALM_X1轴伺服故障      : INT := 102;  // X1轴伺服驱动器故障
    ALM_升降下降超时      : INT := 103;  // 升降气缸下降未到位
    ALM_升降上升超时      : INT := 104;  // 升降气缸上升未到位
    ALM_夹紧超时          : INT := 105;  // 夹爪夹紧未到位
    ALM_松开超时          : INT := 106;  // 夹爪松开未到位
    ALM_产品检测失败      : INT := 107;  // 产品检测失败(缺长边或短边)
    ALM_移动超时          : INT := 108;  // X1轴移动超时

    (*--------------------------------------------------------------------------
      默认定时参数 (单位: ms, 可通过输入参数覆盖)
      --------------------------------------------------------------------------*)
    T_DEF_升降动作时间    : INT := 2000;    // 升降气缸动作时间(上下行程)
    T_DEF_夹紧确认时间    : INT := 800;     // 夹爪夹紧确认时间
    T_DEF_松开确认时间    : INT := 800;     // 夹爪松开确认时间
    T_DEF_产品检测稳定时间 : INT := 300;    // 产品检测稳定等待时间
    T_DEF_移动超时时间    : INT := 5000;    // X1轴移动超时保护
    T_DEF_放料完成保持时间 : INT := 500;    // 放料完成信号保持时间
    T_DEF_初始化超时      : INT := 10000;   // 初始化总超时(10s)

    (*--- 层数常量 ---*)
    LAYER_TOTAL           : INT := 4;       // 总层数
    PICK_TIMES            : INT := 2;       // 取料次数(每次取2层, 共2次取完4层)
END_VAR


(*==============================================================================
 主程序开始
 ==============================================================================*)

//==============================================================================
// 第一部分: 使能与初始化处理
//==============================================================================

(*--- 使能失效时的安全处理: 全部输出归零, 状态复位 ---*)
IF NOT i_b使能 THEN
    (* 清零所有气缸输出 *)
    o_b升降_上升           := FALSE;
    o_b升降_下降           := FALSE;
    o_b前夹紧_夹紧         := FALSE;
    o_b前夹紧_松开         := FALSE;
    o_b后夹紧_夹紧         := FALSE;
    o_b后夹紧_松开         := FALSE;
    o_b前夹紧2_夹紧        := FALSE;
    o_b前夹紧2_松开        := FALSE;
    o_b后夹紧2_夹紧        := FALSE;
    o_b后夹紧2_松开        := FALSE;

    (* 清零所有伺服输出 *)
    o_bZ轴_脉冲输出        := FALSE;
    o_bZ轴_方向输出        := FALSE;
    o_bZ轴_伺服使能        := FALSE;

    (* 清零下游信号 *)
    o_b放料完成_给送料机构 := FALSE;

    (* 清零所有状态 *)
    s_i步序               := STP_空闲;
    s_b运行中             := FALSE;
    s_b故障               := FALSE;
    s_b启动触发           := FALSE;
    s_i已完成层数         := 0;
    s_i当前取料层号       := 0;
    s_i取料次数           := 0;
    s_b放料完成脉冲       := FALSE;
    s_b产品检测通过       := FALSE;

    (* 清零运动请求 *)
    s_bZ轴请求下降        := FALSE;
    s_bZ轴请求上升        := FALSE;
    s_bX1轴请求前移       := FALSE;
    s_bX1轴请求后移       := FALSE;
    s_bX1轴在取料位       := FALSE;
    s_bX1轴在放料位       := FALSE;

    (* 清零报警 *)
    s_i活跃报警           := 0;
    o_i本站报警代码       := 0;
    o_b故障               := FALSE;
    s_b初始化完成         := FALSE;
    s_b初始化中           := FALSE;

    (* 清零状态输出 *)
    o_b运行中             := FALSE;
    o_i当前状态           := STP_空闲;
    o_i当前取料层数       := 0;

    (* 停止所有定时器 *)
    s_t动作定时器(IN := FALSE);
    s_t产品检测稳定定时器(IN := FALSE);
    s_t初始化定时器(IN := FALSE);
    s_t放料完成保持定时器(IN := FALSE);

    RETURN;  (* 退出功能块, 不执行后续逻辑 *)
END_IF;


//==============================================================================
// 第二部分: 初始化流程 (上电或复位后首次使能时执行)
//==============================================================================

IF NOT s_b初始化完成 THEN
    s_b初始化中 := TRUE;

    (* 初始化定时器: 防止初始化卡死 *)
    s_t初始化定时器(IN := TRUE, PT := T_DEF_初始化超时);

    (* 初始化动作:
       1. 所有气缸回到安全位置(上升/松开状态)
       2. 伺服使能(准备回原点或保持当前位置)
       3. 状态清零
    *)

    (* 气缸安全位置: 升降上升, 所有夹紧松开 *)
    o_b升降_上升           := TRUE;   (* 上升 *)
    o_b升降_下降           := FALSE;
    o_b前夹紧_夹紧         := FALSE;
    o_b前夹紧_松开         := TRUE;   (* 松开 *)
    o_b后夹紧_夹紧         := FALSE;
    o_b后夹紧_松开         := TRUE;   (* 松开 *)
    o_b前夹紧2_夹紧        := FALSE;
    o_b前夹紧2_松开        := TRUE;   (* 松开 *)
    o_b后夹紧2_夹紧        := FALSE;
    o_b后夹紧2_松开        := TRUE;   (* 松开 *)

    (* 伺服使能: 使能Z轴伺服(实际回原点由主控统一协调) *)
    o_bZ轴_伺服使能        := TRUE;
    o_bZ轴_脉冲输出        := FALSE;
    o_bZ轴_方向输出        := FALSE;

    (* 下游信号清零 *)
    o_b放料完成_给送料机构 := FALSE;

    (* 步序归零 *)
    s_i步序               := STP_空闲;
    s_b故障               := FALSE;
    s_i活跃报警           := 0;

    (* 检查初始化条件:
       升降在原点(上位) AND 所有夹紧在原点(松开位)
       或 超时强制完成(允许在有报警情况下继续, 报警单独处理)
    *)
    IF (i_b升降_原点 AND
        i_b前夹紧_原点 AND i_b后夹紧_原点 AND
        i_b前夹紧2_原点 AND i_b后夹紧2_原点)
       OR s_t初始化定时器.Q THEN
        (* 初始化完成 或 超时强制完成 *)
        s_b初始化完成 := TRUE;
        s_b初始化中 := FALSE;
        s_t初始化定时器(IN := FALSE);

        (* 初始化完成后关闭气缸输出(进入空闲态的安全状态) *)
        o_b升降_上升       := FALSE;
        o_b前夹紧_松开     := FALSE;
        o_b后夹紧_松开     := FALSE;
        o_b前夹紧2_松开    := FALSE;
        o_b后夹紧2_松开    := FALSE;
    END_IF;

    (* 初始化期间不执行自动/手动逻辑 *)
    o_b运行中 := FALSE;
    o_i当前状态 := STP_空闲;
    o_i当前取料层数 := 0;
    RETURN;
END_IF;


//==============================================================================
// 第三部分: 伺服故障检测 (所有模式共用, 最高优先级)
//==============================================================================

(*--- Z轴伺服故障检测 ---*)
IF i_bZ轴_伺服故障 THEN
    IF s_i活跃报警 <> ALM_Z轴伺服故障 THEN
        s_i活跃报警 := ALM_Z轴伺服故障;
        s_b故障 := TRUE;
    END_IF;
    (* 伺服故障时立即停止Z轴输出 *)
    o_bZ轴_脉冲输出 := FALSE;
ELSIF s_i活跃报警 = ALM_Z轴伺服故障 THEN
    (* 故障消失且当前只有此报警 -> 清除 *)
    s_i活跃报警 := 0;
    s_b故障 := FALSE;
END_IF;

(*--- X1轴伺服故障检测 ---*)
IF i_bX1轴_伺服故障 THEN
    IF s_i活跃报警 <> ALM_X1轴伺服故障 THEN
        s_i活跃报警 := ALM_X1轴伺服故障;
        s_b故障 := TRUE;
    END_IF;
ELSIF s_i活跃报警 = ALM_X1轴伺服故障 THEN
    s_i活跃报警 := 0;
    s_b故障 := FALSE;
END_IF;


//==============================================================================
// 第四部分: 传感器冲突检测 (所有模式共用)
//==============================================================================

(*--- 升降气缸传感器冲突: 上下位同时为TRUE ---*)
s_b升降冲突 := i_b升降_动点 AND i_b升降_原点;
IF s_b升降冲突 THEN
    IF s_i活跃报警 = 0 OR s_i活跃报警 > ALM_产品检测失败 THEN
        (* 传感器冲突优先级低于动作超时, 但仍需记录 *)
        (* 此处暂不设独立报警码, 可扩展为109号 *)
    END_IF;
END_IF;

(*--- 各夹紧气缸传感器冲突检测 ---*)
s_b前夹紧冲突 := i_b前夹紧_动点 AND i_b前夹紧_原点;
s_b后夹紧冲突 := i_b后夹紧_动点 AND i_b后夹紧_原点;
s_b前夹紧2冲突 := i_b前夹紧2_动点 AND i_b前夹紧2_原点;
s_b后夹紧2冲突 := i_b后夹紧2_动点 AND i_b后夹紧2_原点;


//==============================================================================
// 第五部分: 模式分发 (自动/手动)
//==============================================================================

IF i_b自动模式 THEN
    (*==========================================================================
      自动模式: 执行11步取放料状态机
      =========================================================================*)
    CALL_自动模式状态机();

ELSIF i_b手动模式 THEN
    (*==========================================================================
      手动模式: 执行手动点动控制
      =========================================================================*)
    CALL_手动模式控制();

ELSE
    (* 无效模式: 停止所有输出, 进入安全状态 *)
    o_b升降_上升           := FALSE;
    o_b升降_下降           := FALSE;
    o_b前夹紧_夹紧         := FALSE;
    o_b前夹紧_松开         := FALSE;
    o_b后夹紧_夹紧         := FALSE;
    o_b后夹紧_松开         := FALSE;
    o_b前夹紧2_夹紧        := FALSE;
    o_b前夹紧2_松开        := FALSE;
    o_b后夹紧2_夹紧        := FALSE;
    o_b后夹紧2_松开        := FALSE;
    o_bZ轴_脉冲输出        := FALSE;
    o_bZ轴_方向输出        := FALSE;
    o_b放料完成_给送料机构 := FALSE;
    s_bZ轴请求下降        := FALSE;
    s_bZ轴请求上升        := FALSE;
    s_bX1轴请求前移       := FALSE;
    s_bX1轴请求后移       := FALSE;

    (* 如果不在故障态, 归零步序 *)
    IF NOT s_b故障 THEN
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
    END_IF;
END_IF;


//==============================================================================
// 第六部分: 停止与复位处理
//==============================================================================

(*--- 全局停止: 停止自动循环, 保持当前位置 ---*)
IF i_b停止 THEN
    IF s_b运行中 AND NOT s_b故障 THEN
        (* 停止并复位到空闲 *)
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
        s_b启动触发 := FALSE;

        (* 停止所有输出 *)
        o_b升降_上升           := FALSE;
        o_b升降_下降           := FALSE;
        o_b前夹紧_夹紧         := FALSE;
        o_b前夹紧_松开         := FALSE;
        o_b后夹紧_夹紧         := FALSE;
        o_b后夹紧_松开         := FALSE;
        o_b前夹紧2_夹紧        := FALSE;
        o_b前夹紧2_松开        := FALSE;
        o_b后夹紧2_夹紧        := FALSE;
        o_b后夹紧2_松开        := FALSE;
        o_b前夹紧2_夹紧        := FALSE;
        o_b前夹紧2_松开        := FALSE;
        o_b后夹紧2_夹紧        := FALSE;
        o_b后夹紧2_松开        := FALSE;
        o_bZ轴_脉冲输出        := FALSE;
        o_bZ轴_方向输出        := FALSE;
        o_b放料完成_给送料机构 := FALSE;

        (* 停止运动请求 *)
        s_bZ轴请求下降        := FALSE;
        s_bZ轴请求上升        := FALSE;
        s_bX1轴请求前移       := FALSE;
        s_bX1轴请求后移       := FALSE;

        (* 停止定时器 *)
        s_t动作定时器(IN := FALSE);
        s_t产品检测稳定定时器(IN := FALSE);
        s_t放料完成保持定时器(IN := FALSE);
    END_IF;
END_IF;


(*--- 全局复位: 清除所有报警和故障, 重新初始化 ---*)
IF i_b复位 THEN
    IF s_b故障 THEN
        (* 清除报警和故障标志 *)
        s_i活跃报警 := 0;
        s_b故障 := FALSE;
        o_i本站报警代码 := 0;

        (* 归零步序和计数器 *)
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
        s_b启动触发 := FALSE;
        s_i已完成层数 := 0;
        s_i当前取料层号 := 0;
        s_i取料次数 := 0;
        s_b放料完成脉冲 := FALSE;
        s_b产品检测通过 := FALSE;

        (* 安全输出状态: 全部归零 *)
        o_b升降_上升           := FALSE;
        o_b升降_下降           := FALSE;
        o_b前夹紧_夹紧         := FALSE;
        o_b前夹紧_松开         := FALSE;
        o_b后夹紧_夹紧         := FALSE;
        o_b后夹紧_松开         := FALSE;
        o_b前夹紧2_夹紧        := FALSE;
        o_b前夹紧2_松开        := FALSE;
        o_b后夹紧2_夹紧        := FALSE;
        o_b后夹紧2_松开        := FALSE;
        o_b前夹紧2_夹紧        := FALSE;
        o_b前夹紧2_松开        := FALSE;
        o_b后夹紧2_夹紧        := FALSE;
        o_b后夹紧2_松开        := FALSE;
        o_bZ轴_脉冲输出        := FALSE;
        o_bZ轴_方向输出        := FALSE;
        o_b放料完成_给送料机构 := FALSE;

        (* 停止运动请求 *)
        s_bZ轴请求下降        := FALSE;
        s_bZ轴请求上升        := FALSE;
        s_bX1轴请求前移       := FALSE;
        s_bX1轴请求后移       := FALSE;
        s_bX1轴在取料位       := FALSE;
        s_bX1轴在放料位       := FALSE;

        (* 停止定时器 *)
        s_t动作定时器(IN := FALSE);
        s_t产品检测稳定定时器(IN := FALSE);
        s_t放料完成保持定时器(IN := FALSE);

        (* 要求重新初始化 *)
        s_b初始化完成 := FALSE;
    END_IF;
END_IF;


//==============================================================================
// 第七部分: 状态输出汇总
//==============================================================================

(*--- 运行中标志 ---*)
o_b运行中 := s_b运行中;

(*--- 故障标志 ---*)
o_b故障 := s_b故障;

(*--- 当前状态码 ---*)
IF s_b故障 THEN
    o_i当前状态 := 99;  (* 故障状态显示99 *)
ELSE
    o_i当前状态 := s_i步序;
END_IF;

(*--- 当前取料层数 ---*)
IF s_b运行中 THEN
    o_i当前取料层数 := s_i当前取料层号;
ELSIF s_i已完成层数 >= LAYER_TOTAL THEN
    o_i当前取料层数 := 0;  (* 全部完成, 空闲 *)
ELSE
    o_i当前取料层数 := 0;  (* 空闲状态 *)
END_IF;

(*--- 本站报警代码 ---*)
o_i本站报警代码 := s_i活跃报警;


(*==============================================================================
 子程序: 自动模式状态机 (11步完整取放料循环)
   核心工艺: 一次取两根边框, 4层循环取2次
   取料顺序: 第1次取L1+L2(相邻两层), 第2次取L3+L4(相邻两层)
  ==============================================================================*)
METHOD CALL_自动模式状态机 : VOID

    (*--- 故障时不执行状态机 ---*)
    IF s_b故障 THEN
        s_b运行中 := FALSE;
        (* 故障安全输出: 全部停止 *)
        o_b升降_上升           := FALSE;
        o_b升降_下降           := FALSE;
        o_b前夹紧_夹紧         := FALSE;
        o_b前夹紧_松开         := FALSE;
        o_b后夹紧_夹紧         := FALSE;
        o_b后夹紧_松开         := FALSE;
        o_b前夹紧2_夹紧        := FALSE;
        o_b前夹紧2_松开        := FALSE;
        o_b后夹紧2_夹紧        := FALSE;
        o_b后夹紧2_松开        := FALSE;
        o_bZ轴_脉冲输出        := FALSE;
        o_bZ轴_方向输出        := FALSE;
        o_b放料完成_给送料机构 := FALSE;
        s_bZ轴请求下降        := FALSE;
        s_bZ轴请求上升        := FALSE;
        s_bX1轴请求前移       := FALSE;
        s_bX1轴请求后移       := FALSE;
        s_t动作定时器(IN := FALSE);
        s_t产品检测稳定定时器(IN := FALSE);
        RETURN;
    END_IF;

    (*--- 启动触发检测 (上升沿) ---*)
    IF i_b启动 AND NOT s_b启动触发 THEN
        s_b启动触发 := TRUE;
        (* 重置循环计数器 *)
        IF s_i已完成层数 >= LAYER_TOTAL THEN
            s_i已完成层数 := 0;
        END_IF;
        (* 计算当前取料次数和层号 *)
        s_i取料次数 := (s_i已完成层数 / 2) + 1;
        IF s_i取料次数 > PICK_TIMES THEN
            s_i取料次数 := 1;
            s_i已完成层数 := 0;
        END_IF;
    END_IF;

    (*--- 单例状态机 (全局唯一, 因为只有一个取放料机构) ---*)
    CASE s_i步序 OF

    (*======================================================================
     步骤0: 空闲待机
     等待启动触发, 收到启动后进入等待放料完成
     ======================================================================*)
    STP_空闲:
        s_b运行中 := FALSE;
        (* 安全输出状态: 全部归零 *)
        o_b升降_上升           := FALSE;
        o_b升降_下降           := FALSE;
        o_b前夹紧_夹紧         := FALSE;
        o_b前夹紧_松开         := FALSE;
        o_b后夹紧_夹紧         := FALSE;
        o_b后夹紧_松开         := FALSE;
        o_bZ轴_脉冲输出        := FALSE;
        o_bZ轴_方向输出        := FALSE;
        o_b放料完成_给送料机构 := FALSE;
        s_bZ轴请求下降        := FALSE;
        s_bZ轴请求上升        := FALSE;
        s_bX1轴请求前移       := FALSE;
        s_bX1轴请求后移       := FALSE;
        s_i当前取料层号       := 0;

        (* 启动条件: 收到启动触发 *)
        IF s_b启动触发 THEN
            s_i步序 := STP_等待放料完成;
            s_b运行中 := TRUE;
            (* 计算本次要取的层号 *)
            IF s_i已完成层数 < 2 THEN
                (* 第1次取料: 取L1+L2层 *)
                s_i当前取料层号 := 1;  (* 表示正在取第1-2层 *)
            ELSE
                (* 第2次取料: 取L3+L4层 *)
                s_i当前取料层号 := 3;  (* 表示正在取第3-4层 *)
            END_IF;
        END_IF;

    (*======================================================================
     步骤1: 等待输送机放料完成
     根据当前取料次数判断需要等待哪些层的放料完成信号
     第1次取料(L1+L2): 等待L1和L2都放料完成
     第2次取料(L3+L4): 等待L3和L4都放料完成
     ======================================================================*)
    STP_等待放料完成:
        (* 等待对应层的放料完成信号 *)
        IF s_i已完成层数 < 2 THEN
            (* 第1次: 等待L1和L2放料完成 *)
            IF i_b输送机_L1_放料完成 AND i_b输送机_L2_放料完成 THEN
                (* 两层都已放料完成, 可以开始取料 *)
                s_i步序 := STP_取料下降;
                (* 启动升降下降定时器 *)
                s_t动作定时器(IN := TRUE,
                    PT := UINT_TO_INT(TIME_TO_UINT(T#MS * i_i升降动作时间)));
                IF i_i升降动作时间 = 0 THEN
                    s_t动作定时器(PT := T_DEF_升降动作时间);
                END_IF;
                (* 请求Z轴下降 *)
                s_bZ轴请求下降 := TRUE;
                s_bZ轴请求上升 := FALSE;
                o_bZ轴_脉冲输出 := TRUE;
                o_bZ轴_方向输出 := TRUE;  (* 方向: 下降 *)
            END_IF;
        ELSE
            (* 第2次: 等待L3和L4放料完成 *)
            IF i_b输送机_L3_放料完成 AND i_b输送机_L4_放料完成 THEN
                s_i步序 := STP_取料下降;
                s_t动作定时器(IN := TRUE,
                    PT := UINT_TO_INT(TIME_TO_UINT(T#MS * i_i升降动作时间)));
                IF i_i升降动作时间 = 0 THEN
                    s_t动作定时器(PT := T_DEF_升降动作时间);
                END_IF;
                s_bZ轴请求下降 := TRUE;
                s_bZ轴请求上升 := FALSE;
                o_bZ轴_脉冲输出 := TRUE;
                o_bZ轴_方向输出 := TRUE;  (* 方向: 下降 *)
            END_IF;
        END_IF;

    (*======================================================================
     步骤2: 取料下降 (Z轴下降到取料高度)
     等待升降气缸动点(下位)信号或超时
     ======================================================================*)
    STP_取料下降:
        (* 保持Z轴下降输出 *)
        o_bZ轴_脉冲输出 := TRUE;
        o_bZ轴_方向输出 := TRUE;  (* 下降方向 *)
        o_b升降_下降 := TRUE;       (* 升降气缸下降辅助 *)
        o_b升降_上升 := FALSE;

        IF i_b升降_动点 THEN
            (* 升降下降到位, 转入夹紧步骤 *)
            s_t动作定时器(IN := FALSE);
            s_bZ轴请求下降 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_下降 := FALSE;
            s_i步序 := STP_夹爪夹紧;
            (* 启动夹紧确认定时器 *)
            s_t动作定时器(IN := TRUE,
                PT := UINT_TO_INT(TIME_TO_UINT(T#MS * i_i夹紧确认时间)));
            IF i_i夹紧确认时间 = 0 THEN
                s_t动作定时器(PT := T_DEF_夹紧确认时间);
            END_IF;
            (* 同时夹紧前后夹爪(一次取两根) *)
            o_b前夹紧_夹紧 := TRUE;
            o_b后夹紧_夹紧 := TRUE;
        ELSIF s_t动作定时器.Q THEN
            (* 超时: 升降下降未到位 *)
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_升降下降超时;
            s_b故障 := TRUE;
            s_bZ轴请求下降 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_下降 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤3: 夹爪夹紧 (前后夹紧同时动作, 一次取两根边框)
     等待夹紧确认时间到或传感器确认
     ======================================================================*)
    STP_夹爪夹紧:
        (* 保持夹紧输出: 前后夹紧同时夹紧 *)
        o_b前夹紧_夹紧 := TRUE;
        o_b后夹紧_夹紧 := TRUE;
        o_b前夹紧_松开 := FALSE;
        o_b后夹紧_松开 := FALSE;

        (* 夹紧到位判断: 时间到 OR 传感器确认(动点ON) *)
        IF s_t动作定时器.Q OR
           (i_b前夹紧_动点 AND i_b后夹紧_动点) THEN
            s_t动作定时器(IN := FALSE);
            s_i步序 := STP_产品检测;
            (* 启动产品检测稳定定时器 *)
            s_t产品检测稳定定时器(IN := TRUE,
                PT := T_DEF_产品检测稳定时间);
        ELSIF s_t动作定时器.Q AND
              NOT (i_b前夹紧_动点 AND i_b后夹紧_动点) THEN
            (* 超时且传感器未确认 -> 夹紧超时报警 *)
            (* 注意: 此处用第二个定时器Q判断, 实际上面已先判断Q *)
        END_IF;

        (* 夹紧超时检测: 如果定时器到但传感器没确认 *)
        IF s_t动作定时器.Q AND
           NOT (i_b前夹紧_动点 AND i_b后夹紧_动点) THEN
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_夹紧超时;
            s_b故障 := TRUE;
            o_b前夹紧_夹紧 := FALSE;
            o_b后夹紧_夹紧 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤4: 产品检测 (确认长边+短边共4个传感器都有信号)
     一次取两根边框: 需要2个长边+2个短边全部检测到
     ======================================================================*)
    STP_产品检测:
        (* 保持夹紧状态, 等待产品检测稳定 *)
        o_b前夹紧_夹紧 := TRUE;
        o_b后夹紧_夹紧 := TRUE;

        IF s_t产品检测稳定定时器.Q THEN
            s_t产品检测稳定定时器(IN := FALSE);

            (* 产品检测判断: 4个传感器全为TRUE *)
            s_b产品检测通过 :=
                i_b长边1检测 AND i_b长边2检测 AND
                i_b短边1检测 AND i_b短边2检测;

            IF s_b产品检测通过 THEN
                (* 产品检测通过, 转入取料上升 *)
                s_i步序 := STP_取料上升;
                (* 启动上升定时器 *)
                s_t动作定时器(IN := TRUE,
                    PT := UINT_TO_INT(TIME_TO_UINT(T#MS * i_i升降动作时间)));
                IF i_i升降动作时间 = 0 THEN
                    s_t动作定时器(PT := T_DEF_升降动作时间);
                END_IF;
                (* 请求Z轴上升 *)
                s_bZ轴请求上升 := TRUE;
                o_bZ轴_脉冲输出 := TRUE;
                o_bZ轴_方向输出 := FALSE;  (* 方向: 上升 *)
                o_b升降_上升 := TRUE;
                o_b前夹紧_夹紧 := FALSE;  (* 保持夹紧但关闭输出, 由机械自锁保持 *)
                o_b后夹紧_夹紧 := FALSE;
            ELSE
                (* 产品检测失败: 缺少长边或短边 *)
                s_i活跃报警 := ALM_产品检测失败;
                s_b故障 := TRUE;
                o_b前夹紧_夹紧 := FALSE;
                o_b后夹紧_夹紧 := FALSE;
                s_i步序 := STP_空闲;
                s_b运行中 := FALSE;
                s_b启动触发 := FALSE;
            END_IF;
        END_IF;

    (*======================================================================
     步骤5: 取料上升 (Z轴上升到安全高度)
     等待升降原点(上位)信号或超时
     ======================================================================*)
    STP_取料上升:
        (* 保持Z轴上升输出 *)
        o_bZ轴_脉冲输出 := TRUE;
        o_bZ轴_方向输出 := FALSE;  (* 上升方向 *)
        o_b升降_上升 := TRUE;
        o_b升降_下降 := FALSE;

        IF i_b升降_原点 THEN
            (* 上升到位, 转入移动到放料位置 *)
            s_t动作定时器(IN := FALSE);
            s_bZ轴请求上升 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_上升 := FALSE;
            s_i步序 := STP_移动到放料位置;
            (* 启动移动超时定时器 *)
            s_t动作定时器(IN := TRUE, PT := T_DEF_移动超时时间);
            (* 请求X1轴向后移动(去放料位置) *)
            s_bX1轴请求前移 := FALSE;
            s_bX1轴请求后移 := TRUE;
            s_bX1轴在取料位 := FALSE;
        ELSIF s_t动作定时器.Q THEN
            (* 超时: 上升未到位 *)
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_升降上升超时;
            s_b故障 := TRUE;
            s_bZ轴请求上升 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_上升 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤6: 移动到放料位置 (X1轴水平移动到打胶机侧)
     等待X1轴到达放料位置或超时
     注: X1轴的实际脉冲输出由主控根据请求标志处理
     ======================================================================*)
    STP_移动到放料位置:
        (* 保持X1轴后移请求 *)
        s_bX1轴请求后移 := TRUE;
        s_bX1轴请求前移 := FALSE;

        (* 到达放料位置的判断:
           由主控在X1轴到达目标位置后置位s_bX1轴在放料位
           或通过X1轴反向限位信号判断(如果放料位置在反向限位处)
        *)
        IF s_bX1轴在放料位 OR i_bX1轴_反向限位 THEN
            (* 到达放料位置, 转入放料下降 *)
            s_t动作定时器(IN := FALSE);
            s_bX1轴请求后移 := FALSE;
            s_bX1轴在放料位 := TRUE;
            s_i步序 := STP_放料下降;
            (* 启动下降定时器 *)
            s_t动作定时器(IN := TRUE,
                PT := UINT_TO_INT(TIME_TO_UINT(T#MS * i_i升降动作时间)));
            IF i_i升降动作时间 = 0 THEN
                s_t动作定时器(PT := T_DEF_升降动作时间);
            END_IF;
            (* 请求Z轴下降 *)
            s_bZ轴请求下降 := TRUE;
            o_bZ轴_脉冲输出 := TRUE;
            o_bZ轴_方向输出 := TRUE;  (* 下降方向 *)
            o_b升降_下降 := TRUE;
        ELSIF s_t动作定时器.Q THEN
            (* 超时: X1轴移动未到位 *)
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_移动超时;
            s_b故障 := TRUE;
            s_bX1轴请求后移 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤7: 放料下降 (Z轴下降到放料高度)
     等待升降动点(下位)信号或超时
     ======================================================================*)
    STP_放料下降:
        (* 保持Z轴下降输出 *)
        o_bZ轴_脉冲输出 := TRUE;
        o_bZ轴_方向输出 := TRUE;  (* 下降方向 *)
        o_b升降_下降 := TRUE;
        o_b升降_上升 := FALSE;

        IF i_b升降_动点 THEN
            (* 下降到位, 转入夹爪松开 *)
            s_t动作定时器(IN := FALSE);
            s_bZ轴请求下降 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_下降 := FALSE;
            s_i步序 := STP_夹爪松开;
            (* 启动松开确认定时器 *)
            s_t动作定时器(IN := TRUE,
                PT := T_DEF_松开确认时间);
            (* 同时松开前后夹爪 *)
            o_b前夹紧_松开 := TRUE;
            o_b后夹紧_松开 := TRUE;
        ELSIF s_t动作定时器.Q THEN
            (* 超时: 下降未到位 *)
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_升降下降超时;
            s_b故障 := TRUE;
            s_bZ轴请求下降 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_下降 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤8: 夹爪松开 (前后夹紧同时松开, 释放边框到放料位置)
     等待松开确认时间到或传感器确认(原点ON)
     ======================================================================*)
    STP_夹爪松开:
        (* 保持松开输出 *)
        o_b前夹紧_松开 := TRUE;
        o_b后夹紧_松开 := TRUE;
        o_b前夹紧_夹紧 := FALSE;
        o_b后夹紧_夹紧 := FALSE;

        (* 松开到位判断: 时间到 OR 传感器确认(原点ON) *)
        IF s_t动作定时器.Q OR
           (i_b前夹紧_原点 AND i_b后夹紧_原点) THEN
            s_t动作定时器(IN := FALSE);
            s_i步序 := STP_放料上升;
            (* 启动上升定时器 *)
            s_t动作定时器(IN := TRUE,
                PT := UINT_TO_INT(TIME_TO_UINT(T#MS * i_i升降动作时间)));
            IF i_i升降动作时间 = 0 THEN
                s_t动作定时器(PT := T_DEF_升降动作时间);
            END_IF;
            (* 请求Z轴上升 *)
            s_bZ轴请求上升 := TRUE;
            o_bZ轴_脉冲输出 := TRUE;
            o_bZ轴_方向输出 := FALSE;  (* 上升方向 *)
            o_b升降_上升 := TRUE;
            o_b前夹紧_松开 := FALSE;  (* 关闭松开输出 *)
            o_b后夹紧_松开 := FALSE;
        ELSIF s_t动作定时器.Q AND
              NOT (i_b前夹紧_原点 AND i_b后夹紧_原点) THEN
            (* 超时且传感器未确认 *)
        END_IF;

        (* 松开超时检测 *)
        IF s_t动作定时器.Q AND
           NOT (i_b前夹紧_原点 AND i_b后夹紧_原点) THEN
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_松开超时;
            s_b故障 := TRUE;
            o_b前夹紧_松开 := FALSE;
            o_b后夹紧_松开 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤9: 放料上升 (Z轴上升到安全高度)
     等待升降原点(上位)信号或超时
     ======================================================================*)
    STP_放料上升:
        (* 保持Z轴上升输出 *)
        o_bZ轴_脉冲输出 := TRUE;
        o_bZ轴_方向输出 := FALSE;  (* 上升方向 *)
        o_b升降_上升 := TRUE;
        o_b升降_下降 := FALSE;

        IF i_b升降_原点 THEN
            (* 上升到位, 转入放料完成通知 *)
            s_t动作定时器(IN := FALSE);
            s_bZ轴请求上升 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_上升 := FALSE;
            s_i步序 := STP_放料完成通知;
            (* 启动放料完成保持定时器 *)
            s_t放料完成保持定时器(IN := TRUE,
                PT := T_DEF_放料完成保持时间);
            (* 发送放料完成信号 *)
            o_b放料完成_给送料机构 := TRUE;
            s_b放料完成脉冲 := TRUE;
        ELSIF s_t动作定时器.Q THEN
            (* 超时: 上升未到位 *)
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_升降上升超时;
            s_b故障 := TRUE;
            s_bZ轴请求上升 := FALSE;
            o_bZ轴_脉冲输出 := FALSE;
            o_b升降_上升 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤10: 放料完成通知 (发送放料完成信号给下游打胶机)
     保持一段时间后, 更新层数计数器, 回到等待放料完成或空闲
     ======================================================================*)
    STP_放料完成通知:
        (* 保持放料完成信号 *)
        o_b放料完成_给送料机构 := TRUE;

        IF s_t放料完成保持定时器.Q THEN
            s_t放料完成保持定时器(IN := FALSE);
            o_b放料完成_给送料机构 := FALSE;
            s_b放料完成脉冲 := FALSE;

            (* 更新已完成层数: 一次取两层, 所以+2 *)
            s_i已完成层数 := s_i已完成层数 + 2;

            (* 检查是否全部完成(4层) *)
            IF s_i已完成层数 >= LAYER_TOTAL THEN
                (* 4层全部取放料完成(2次循环), 回到空闲 *)
                s_i已完成层数 := 0;  (* 重置计数器 *)
                s_i步序 := STP_空闲;
                s_b运行中 := FALSE;
                s_b启动触发 := FALSE;  (* 等待下一轮启动 *)
                s_i当前取料层号 := 0;
            ELSE
                (* 还有层未完成, 继续循环: 回到等待放料完成 *)
                s_i步序 := STP_等待放料完成;
                (* 更新当前取料层号 *)
                IF s_i已完成层数 < 2 THEN
                    s_i当前取料层号 := 1;  (* 继续取L1+L2区域 *)
                ELSE
                    s_i当前取料层号 := 3;  (* 继续取L3+L4区域 *)
                END_IF;
            END_IF;
        END_IF;

    ELSE
        (* 无效步序: 强制归零 *)
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;

    END_CASE;


(*==============================================================================
 子程序: 手动模式控制 (14个手动操作, 带互锁和安全限制)
  ==============================================================================*)
METHOD CALL_手动模式控制 : VOID

    (*--- 故障时禁止手动操作 ---*)
    IF s_b故障 THEN
        s_b手动允许 := FALSE;
        o_b升降_上升           := FALSE;
        o_b升降_下降           := FALSE;
        o_b前夹紧_夹紧         := FALSE;
        o_b前夹紧_松开         := FALSE;
        o_b后夹紧_夹紧         := FALSE;
        o_b后夹紧_松开         := FALSE;
        o_bZ轴_脉冲输出        := FALSE;
        o_bZ轴_方向输出        := FALSE;
        o_b放料完成_给送料机构 := FALSE;
        s_bZ轴请求下降        := FALSE;
        s_bZ轴请求上升        := FALSE;
        s_bX1轴请求前移       := FALSE;
        s_bX1轴请求后移       := FALSE;
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
        RETURN;
    END_IF;

    s_b手动允许 := TRUE;
    s_b运行中 := FALSE;
    s_i步序 := STP_空闲;  (* 手动模式下步序显示为空闲 *)
    o_i当前取料层数 := 0;
    o_b放料完成_给送料机构 := FALSE;

    (*======================================================================
     手动操作 - 伺服点动控制 (Z轴/X1轴)
     注意: 伺服的点动脉冲输出由主控根据请求标志处理
     本功能块只输出请求标志和方向信号
     ======================================================================*)

    (*--- Z轴点动: 上升/下降互锁 ---*)
    IF i_bZ轴点动上 AND NOT i_bZ轴点动下 THEN
        (* Z轴向上点动 *)
        (* 检查是否已到正向限位(上限位) *)
        IF NOT i_bZ轴_正向限位 THEN
            s_bZ轴请求上升 := TRUE;
            s_bZ轴请求下降 := FALSE;
            o_bZ轴_方向输出 := FALSE;  (* 上升方向 *)
            (* 点动脉冲输出: 由主控处理, 此处仅做标记 *)
        END_IF;
    ELSIF i_bZ轴点动下 AND NOT i_bZ轴点动上 THEN
        (* Z轴向下点动 *)
        (* 检查是否已到反向限位(下限位) *)
        IF NOT i_bZ轴_反向限位 THEN
            s_bZ轴请求下降 := TRUE;
            s_bZ轴请求上升 := FALSE;
            o_bZ轴_方向输出 := TRUE;  (* 下降方向 *)
        END_IF;
    ELSE
        (* 无Z轴点动操作 *)
        s_bZ轴请求下降 := FALSE;
        s_bZ轴请求上升 := FALSE;
    END_IF;

    (*--- X1轴点动: 前/后互锁 ---*)
    IF i_bX1轴点动前 AND NOT i_bX1轴点动后 THEN
        (* X1轴向前点动(取料方向) *)
        IF NOT i_bX1轴_正向限位 THEN
            s_bX1轴请求前移 := TRUE;
            s_bX1轴请求后移 := FALSE;
        END_IF;
    ELSIF i_bX1轴点动后 AND NOT i_bX1轴点动前 THEN
        (* X1轴向后点动(放料方向) *)
        IF NOT i_bX1轴_反向限位 THEN
            s_bX1轴请求后移 := TRUE;
            s_bX1轴请求前移 := FALSE;
        END_IF;
    ELSE
        (* 无X1轴点动操作 *)
        s_bX1轴请求前移 := FALSE;
        s_bX1轴请求后移 := FALSE;
    END_IF;

    (*======================================================================
     手动操作 - 升降气缸控制 (上升/下降互锁)
     ======================================================================*)
    IF i_b升降上升 AND NOT i_b升降下降 THEN
        (* 上升请求: 检查是否已在原点(上位) *)
        IF i_b升降_原点 THEN
            (* 已到位 *)
        END_IF;
        o_b升降_上升 := TRUE;
        o_b升降_下降 := FALSE;
    ELSIF i_b升降下降 AND NOT i_b升降上升 THEN
        (* 下降请求: 检查是否已在动点(下位) *)
        IF i_b升降_动点 THEN
            (* 已到位 *)
        END_IF;
        o_b升降_下降 := TRUE;
        o_b升降_上升 := FALSE;
    ELSE
        (* 无操作: 保持当前位置 *)
        o_b升降_上升 := FALSE;
        o_b升降_下降 := FALSE;
    END_IF;

    (*======================================================================
     手动操作 - 前夹紧气缸控制 (夹紧/松开互锁)
     ======================================================================*)
    IF i_b前夹紧夹紧 AND NOT i_b前夹紧松开 THEN
        o_b前夹紧_夹紧 := TRUE;
        o_b前夹紧_松开 := FALSE;
    ELSIF i_b前夹紧松开 AND NOT i_b前夹紧夹紧 THEN
        o_b前夹紧_松开 := TRUE;
        o_b前夹紧_夹紧 := FALSE;
    ELSE
        o_b前夹紧_夹紧 := FALSE;
        o_b前夹紧_松开 := FALSE;
    END_IF;

    (*======================================================================
     手动操作 - 后夹紧气缸控制 (夹紧/松开互锁)
     ======================================================================*)
    IF i_b后夹紧夹紧 AND NOT i_b后夹紧松开 THEN
        o_b后夹紧_夹紧 := TRUE;
        o_b后夹紧_松开 := FALSE;
    ELSIF i_b后夹紧松开 AND NOT i_b后夹紧夹紧 THEN
        o_b后夹紧_松开 := TRUE;
        o_b后夹紧_夹紧 := FALSE;
    ELSE
        o_b后夹紧_夹紧 := FALSE;
        o_b后夹紧_松开 := FALSE;
    END_IF;

    (*======================================================================
     手动操作 - 前夹紧2气缸控制 (夹紧/松开互锁, 第二组前夹爪)
     ======================================================================*)
    IF i_b前夹紧2夹紧 AND NOT i_b前夹紧2松开 THEN
        o_b前夹紧2_夹紧 := TRUE;
        o_b前夹紧2_松开 := FALSE;
    ELSIF i_b前夹紧2松开 AND NOT i_b前夹紧2夹紧 THEN
        o_b前夹紧2_松开 := TRUE;
        o_b前夹紧2_夹紧 := FALSE;
    ELSE
        o_b前夹紧2_夹紧 := FALSE;
        o_b前夹紧2_松开 := FALSE;
    END_IF;

    (*======================================================================
     手动操作 - 后夹紧2气缸控制 (夹紧/松开互锁, 第二组后夹爪)
     ======================================================================*)
    IF i_b后夹紧2夹紧 AND NOT i_b后夹紧2松开 THEN
        o_b后夹紧2_夹紧 := TRUE;
        o_b后夹紧2_松开 := FALSE;
    ELSIF i_b后夹紧2松开 AND NOT i_b后夹紧2夹紧 THEN
        o_b后夹紧2_松开 := TRUE;
        o_b后夹紧2_夹紧 := FALSE;
    ELSE
        o_b后夹紧2_夹紧 := FALSE;
        o_b后夹紧2_松开 := FALSE;
    END_IF;


END_FUNCTION_BLOCK

