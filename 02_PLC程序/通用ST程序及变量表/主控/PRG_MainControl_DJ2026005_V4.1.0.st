(* ========================================================================== *)
(* 系统运行中状态汇总                                                         *)
(* 说明: 综合各工站的运行状态, 判断整个系统是否在自动运行中                   *)
(* ========================================================================== *)

(* 系统运行中条件: 自动模式 AND 任一工站在运行 AND 系统使能 *)
IF bHMI_自动模式 AND b系统使能 THEN
    IF bHMI_输送机运行中 OR bHMI_取放料运行中 OR bHMI_送料机构运行中 THEN
        bHMI_系统运行中 := TRUE;
    ELSE
        (* 自动模式下但所有工站都空闲, 可能是在等待启动或循环间隙 *)
        bHMI_系统运行中 := FALSE;
    END_IF;
ELSE
    (* 非自动模式或系统未使能, 肯定不在运行中 *)
    bHMI_系统运行中 := FALSE;
END_IF;


