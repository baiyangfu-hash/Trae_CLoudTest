(* ========================================================================== *)
(* Step3.5: 系统使能计算 (W09修复: 提前到工站调用之前)                        *)
(* 说明: 安全条件满足后置位b系统使能, 供后续Step4~Step6各工站使用             *)
(*       包含本机安全条件和外部设备安全条件                                *)
(* ========================================================================== *)

(* 安全条件检查:
   1. 本机急停按钮未按下 (常闭触点, 正常状态为TRUE)
   2. 前安全门已锁定
   3. 后安全门已锁定
   4. 外部设备安全条件满足 (由FB_外部设备交互功能块提供)
*)
IF NOT i_b急停按钮
   AND i_b前门锁定
   AND i_b后门锁定
   AND fb外部设备交互.q_b系统安全条件满足  (* 外部设备安全条件 *)
THEN
    b系统使能 := TRUE;
    q_b安全继电器启动 := TRUE;
    bHMI_系统就绪 := TRUE;
ELSE
    b系统使能 := FALSE;
    q_b安全继电器启动 := FALSE;
    bHMI_系统就绪 := FALSE;
END_IF;


