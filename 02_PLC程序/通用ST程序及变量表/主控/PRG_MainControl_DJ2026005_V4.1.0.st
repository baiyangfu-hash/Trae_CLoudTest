(* ================================================================= *)
(*  程序名称：PRG_MainControl_DJ2026005                           *)
(*  功能描述：边框缓存机主控协调程序                                 *)
(*  创建日期：2026-04-23                                            *)
(*  规范化修订：2026-04-25                                           *)
(*  版本号：V4.1.0                                                  *)
(*  基于版本：V4.0.0                                                *)
(*  编制人：[待填写]                                                *)
(*  审核人：[待填写]                                                *)
(*                                                                  *)
(*  遵循规范：                                                      *)
(*    - 801_PLC变量命名与功能块命名规范_DEV-V1.0.5                  *)
(*    - 810_PLC编程规范_DEV-V1.0.3                                  *)
(*                                                                  *)
(*  变更记录：                                                        *)
(* ---------------------------------------------------------------- *)
(*  V4.1.0 (2026-04-25) Trae                                      *)
(*  - 修正: 文件头标准化为(* *)格式                                *)
(*  - 修正: 更新遵循规范至最新版本                                  *)
(*  - 优化: 统一注释风格                                           *)
(* ---------------------------------------------------------------- *)
(*  V4.0.0 (2026-04-23) 初始版本                                   *)
(*                                                                  *)
(*  详细说明:                                                        *)
(*    主控程序是系统的核心协调组件,承担以下职责:                      *)
(*    1. IO映射: X地址->逻辑变量(传感器输入), 逻辑变量->Y地址(执行器输出) *)
(*    2. HMI数据交互: M/D区读取(操作指令/参数设定), M/D区回写(状态/报警) *)
(*    3. 外部设备交互:                                              *)
(*       - 下游打胶机: 允许送料(X76), 取料完成(X102), 故障/急停联锁   *)
(*       - 上游组框机: 允许送料, 有料请求, 开门互锁, 安全联锁 (预留接口) *)
(*    4. 工站实例化与连接: 实例化4个功能块并按工艺顺序调用           *)
(*    5. 报警汇总: 调用公共报警管理器,汇总三工站报警并写入D区        *)
(*                                                                  *)
(*  架构特点:                                                        *)
(*    - 纯协调层: 不包含任何业务逻辑(状态机/自动手动判断在工站内部)   *)
(*    - 数据桥梁: 连接物理IO层(X/Y)与逻辑层(功能块接口变量)            *)
(*    - 设备协调: 处理上下游设备的握手、联锁、互锁信号                 *)
(*    - 执行顺序严格: 输入映射->外部信号处理->工站调用->输出映射      *)
(*    - 接口预留: 组框机信号使用占位符, 待现场确定物理地址后激活     *)
(*                                                                  *)
(*  外部设备交互协议:                                                *)
(*    ┌───────────┐    控制信号     ┌──────────────┐    控制信号    ┌───────────┐    *)
(*    │           │ ──────────────> │              │ ──────────────> │           │    *)
(*    │  组框机   │               │  边框缓存机   │               │  打胶机   │    *)
(*    │ (上游)    │ <────────────── │   (本设备)    │ <────────────── │ (下游)    │    *)
(*    │           │    边框流入     │              │    边框流入     │           │    *)
(*    └───────────┘               └──────────────┘               └───────────┘    *)
(*    说明:                                                           *)
(*    1. 组框机检测到玻璃进入但无边框时, 要求打胶机送边框              *)
(*    2. 打胶机允许送边框信号后, 边框缓存机送边框给打胶机             *)
(*    3. 打胶机打完胶后将边框送到组框机                               *)
(*    4. 组框机完成组框后, 输送机输出组件, 开始下轮循环               *)
(*                                                                  *)
(*  执行顺序(每个扫描周期):                                          *)
(*    Step1: IO映射输入 (X地址 -> 逻辑变量, 含打胶机/组框机DI)        *)
(*    Step2: HMI数据读取 (M/D区 -> 逻辑变量)                          *)
(*    Step3: 外部设备信号处理 (打胶机有效性检查 + 组框机安全联锁)     *)
(*    Step4: 调用fb四层输送机 (传入所有输入, 接收所有输出)             *)
(*    Step5: 调用fb取放料机构 (传入含上游信号的输入)                   *)
(*    Step6: 调用fb打胶机送料机构 (传入含上游+打胶机信号的输入)        *)
(*    Step7: 调用fb公共报警 (汇总各工站报警)                           *)
(*    Step8: IO映射输出 (逻辑变量 -> Y地址, 含打胶机/组框机DO)         *)
(*    Step9: HMI状态回写 (逻辑变量 -> M/D区)                           *)
(*    Step10: 报警D区回写 (公共报警输出 -> D400起始)                    *)
(* ================================================================= *)

PROGRAM PRG_MainControl_DJ2026005

VAR
    (* ========================================================================== *)
    (* 一、工站实例声明 (4个纯逻辑功能块, 无物理地址依赖)                       *)
    (* ========================================================================== *)

    (*--- 工站1: 四层输送机 (独立控制4层分料/输送) ---*)
    fb四层输送机      : FB_1001_Conveyor4Layer_BufferFraming;  (* EN: fbConveyor4Layer *)

    (*--- 工站2: 取放料机构 (Z轴升降+X1轴横移+夹爪控制) ---*)
    fb取放料机构      : FB_1003_PickPlace_BufferFraming;      (* EN: fbPickPlace *)

    (*--- 工站3: 打胶机送料机构 (X2轴横移+打胶机交互) ---*)
    fb打胶机送料机构   : FB_1004_GlueMachineFeeder_BufferFraming;  (* EN: fbGlueMachineFeeder *)

    (*--- 工站4: 公共报警管理器 (汇总三工站报警+MES队列) ---*)
    fb公共报警        : FB_2001_CommonAlarm_AllStation;          (* EN: fbCommonAlarm *)
    
    (*--- 工站5: 外部设备交互 (处理组框机、打胶机、机器人交互) ---*)
    fb外部设备交互    : FB_外部设备交互;                       (* EN: fbExternalDeviceInteraction *)


    (* ========================================================================== *)
    (* 二、四层输送机 - 传感器输入映射 (X地址 -> 逻辑变量)                        *)
    (* 注: 物理地址来自DI扩展模块3(DI3)和DI扩展模块4(DI4)                         *)
    (*     DI3: X0-X17对应4层(L4)和3层(L3), DI4: X0-X17对应2层(L2)和1层(L1)       *)
    (*     数组索引: [1]=第1层(底层/L1), [4]=第4层(顶层/L4)                         *)
    (* ========================================================================== *)

    (*--- 分料前感应器: 检测材料是否到达分料工位入口 ---*)
    (* DI4:X11=L1, DI4:X1=L2, DI3:X11=L3, DI3:X0=L4 *)
    i_bLx_分料前感应器    : ARRAY[1..4] OF BOOL;   // X51,X61,X71,X81

    (*--- 到位感应器1/2: 双传感器冗余检测材料到位 ---*)
    (* DI4:X12/X13=L1, DI4:X2/X3=L2, DI3:X12/X13=L3, DI3:X2/X3=L4 *)
    i_bLx_到位感应器1     : ARRAY[1..4] OF BOOL;   // X52,X62,X72,X82
    i_bLx_到位感应器2     : ARRAY[1..4] OF BOOL;   // X53,X63,X73,X83

    (*--- 阻挡气缸位置反馈 ---*)
    (* DI4:X14/X15=L1, DI4:X4/X5=L2, DI3:X14/X15=L3, DI3:X4/X5=L4 *)
    i_bLx_阻挡气缸上位    : ARRAY[1..4] OF BOOL;   // X54,X64,X74,X84
    i_bLx_阻挡气缸下位    : ARRAY[1..4] OF BOOL;   // X55,X65,X75,X85

    (*--- 分料气缸位置反馈 ---*)
    (* DI4:X16/X17=L1, DI4:X6/X7=L2, DI3:X16/X17=L3, DI3:X6/X7=L4 *)
    i_bLx_分料气缸上位    : ARRAY[1..4] OF BOOL;   // X56,X66,X76,X86
    i_bLx_分料气缸下位    : ARRAY[1..4] OF BOOL;   // X57,X67,X77,X87


    (* ========================================================================== *)
    (* 三、四层输送机 - 执行器输出映射 (逻辑变量 -> Y地址)                        *)
    (* 注: 物理地址来自DO扩展模块1(DO1)和DO扩展模块2(DO2)                         *)
    (*     DO1: Y0-Y5=L4, Y10-Y15=L3 | DO2: Y0-Y5=L2, Y10-Y15=L1                  *)
    (* ========================================================================== *)

    (*--- 阻挡电磁阀: TRUE=下降(阻挡), FALSE=上升(释放) ---*)
    (* DO2:Y10=L1, DO2:Y0=L2, DO1:Y10=L3, DO1:Y0=L4 *)
    q_bLx_阻挡电磁阀      : ARRAY[1..4] OF BOOL;   // Y20,Y21,Y22,Y23

    (*--- 分料电磁阀: TRUE=推出(分料), FALSE=复位 ---*)
    (* DO2:Y11=L1, DO2:Y1=L2, DO1:Y11=L3, DO1:Y1=L4 *)
    q_bLx_分料电磁阀      : ARRAY[1..4] OF BOOL;   // Y24,Y25,Y26,Y27

    (*--- 输送带正转 ---*)
    (* DO2:Y12=L1, DO2:Y2=L2, DO1:Y12=L3, DO1:Y2=L4 *)
    q_bLx_输送带正转      : ARRAY[1..4] OF BOOL;   // Y28,Y29,Y30,Y31

    (*--- 输送带慢速 (精确定位用) ---*)
    (* DO2:Y13=L1, DO2:Y3=L2, DO1:Y13=L3, DO1:Y3=L4 *)
    q_bLx_输送带慢速      : ARRAY[1..4] OF BOOL;   // Y32,Y33,Y34,Y35

    (*--- 输送带反转 (预留) ---*)
    q_bLx_输送带反转     : ARRAY[1..4] OF BOOL;   // 预留: Y24,Y30,Y36,Y42


    (* ========================================================================== *)
    (* 四、取放料机构 - 传感器输入映射                                         *)
    (* 注: 物理地址来自远程IO_1(站号1, CC-Link Basic) + CPU本体(X0-X13)          *)
    (* ========================================================================== *)

    (*--- 气缸位置传感器 (10个磁性开关, 来自Remote_IO X0-X9) ---*)
    (* 升降气缸: 动点=下降到位, 原点=上升到位 *)
    i_b升降_动点          : BOOL;   // Remote_X0
    i_b升降_原点          : BOOL;   // Remote_X1

    (* 前夹紧气缸: 动点=夹紧到位, 原点=松开到位 *)
    i_b前夹紧_动点        : BOOL;   // Remote_X2
    i_b前夹紧_原点        : BOOL;   // Remote_X3

    (* 后夹紧气缸: 动点=夹紧到位, 原点=松开到位 *)
    i_b后夹紧_动点        : BOOL;   // Remote_X4
    i_b后夹紧_原点        : BOOL;   // Remote_X5

    (* 前夹紧2气缸: 第二组前夹爪 *)
    i_b前夹紧2_动点       : BOOL;   // Remote_X6
    i_b前夹紧2_原点       : BOOL;   // Remote_X7

    (* 后夹紧2气缸: 第二组后夹爪 *)
    i_b后夹紧2_动点       : BOOL;   // Remote_X8
    i_b后夹紧2_原点       : BOOL;   // Remote_X9

    (*--- 产品检测传感器 (4个光电传感器, 来自Remote_IO XC-XF) ---*)
    (* 一次取两根边框: 长边×2 + 短边×2 *)
    i_b长边1检测          : BOOL;   // Remote_XC
    i_b长边2检测          : BOOL;   // Remote_XD
    i_b短边1检测          : BOOL;   // Remote_XE
    i_b短边2检测          : BOOL;   // Remote_XF

    (*--- 伺服轴状态信号 (12个, 来自CPU本体X0-X13) ---*)
    (* 原点信号 *)
    i_bZ轴_原点           : BOOL;   // X0
    i_bX1轴_原点          : BOOL;   // X1
    i_bX2轴_原点          : BOOL;   // X2

    (* 伺服故障报警 *)
    i_bZ轴_伺服故障       : BOOL;   // X11
    i_bX1轴_伺服故障      : BOOL;   // X12
    i_bX2轴_伺服故障      : BOOL;   // X13

    (* 限位开关信号 *)
    i_bZ轴_正向限位       : BOOL;   // X3
    i_bZ轴_反向限位       : BOOL;   // X4
    i_bX1轴_正向限位      : BOOL;   // X5
    i_bX1轴_反向限位      : BOOL;   // X6
    i_bX2轴_正向限位      : BOOL;   // X7
    i_bX2轴_反向限位      : BOOL;   // X10


    (* ========================================================================== *)
    (* 五、取放料机构 - 执行器输出映射                                         *)
    (* ========================================================================== *)

    (*--- 气缸控制输出 (6个BOOL, 映射到Remote_IO Y10-Y15) ---*)
    (* 升降气缸: 上升/下降双电磁阀 *)
    q_b升降_上升          : BOOL;   // -> Remote_Y10
    q_b升降_下降          : BOOL;   // -> Remote_Y11

    (* 前夹紧气缸: 夹紧/松开双电磁阀 *)
    q_b前夹紧_夹紧        : BOOL;   // -> Remote_Y12
    q_b前夹紧_松开        : BOOL;   // -> Remote_Y13

    (* 后夹紧气缸: 夹紧/松开双电磁阀 *)
    q_b后夹紧_夹紧        : BOOL;   // -> Remote_Y14
    q_b后夹紧_松开        : BOOL;   // -> Remote_Y15

    (*--- 伺服控制输出 (3个BOOL, 仅Z轴由本程序直接映射到CPU Y地址) ---*)
    (* 注: X1轴/X2轴的脉冲输出由运动控制模块处理, 此处仅做标志传递 *)
    q_bZ轴_脉冲输出       : BOOL;   // -> Y0 (PULSE+)
    q_bZ轴_方向输出       : BOOL;   // -> Y1 (DIR+)
    q_bZ轴_伺服使能       : BOOL;   // -> Y2 (SERVO ON)


    (* ========================================================================== *)
    (* 六、打胶机信号映射 (下游设备: 接收边框并打胶)                             *)
    (* ========================================================================== *)

    (*--- 打胶机输入信号 (来自CPU本体DI, 硬接线/通讯) ---*)
    i_b打胶机_自动中      : BOOL;   // %IX75  占位符: 打胶机自动运行中
    i_b打胶机_允许送料    : BOOL;   // %IX76  (已定义) 打胶机准备好可接收边框
    i_b打胶机_取料完成    : BOOL;   // %IX102 (已定义) 打胶机已完成边框抓取
    i_b打胶机_故障        : BOOL;   // %IX77  占位符: 打胶机设备故障报警
    i_b打胶机_急停        : BOOL;   // %IX78  占位符: 打胶机急停状态
    i_b打胶机_通讯异常    : BOOL;   // %IX79  占位符: 与打胶机通讯中断

    (*--- 打胶机输出信号 (到CPU本体DO, 硬接线/通讯) ---*)
    q_b打胶机_请求运行    : BOOL;   // -> Y40 占位符: 请求打胶机启动运行
    q_b允许抓料            : BOOL;   // -> Y44  (已定义) 通知打胶机可以抓取边框
    q_b安全区信号          : BOOL;   // -> Y47  (已定义) 安全区开放/关闭信号
    q_b打胶机_复位请求    : BOOL;   // -> Y41 占位符: 向打胶机发送复位请求


    (* ========================================================================== *)
    (* 六点五、组框机信号映射 (上游设备: 提供边框)                               *)
    (* ========================================================================== *)

    (*--- 组框机输入信号 (来自CPU本体DI, 地址预留) ---*)
    i_b组框机_自动中      : BOOL;   // 占位符: 组框机自动运行中
    i_b组框机_允许送料    : BOOL;   // 占位符: 组框机允许向缓存机输送边框
    i_b组框机_有料请求    : BOOL;   // 占位符: 组框机有边框需要送入缓存机
    i_b组框机_开门请求    : BOOL;   // 占位符: 组框机操作门打开(需本机暂停)
    i_b组框机_急停        : BOOL;   // 占位符: 组框机急停信号(需联锁)
    i_b组框机_安全异常    : BOOL;   // 占位符: 组框机安全系统异常
    i_b组框机_通讯异常    : BOOL;   // 占位符: 与组框机通讯异常

    (*--- 组框机输出信号 (到CPU本体DO, 地址预留) ---*)
    q_b组框机_请求送料    : BOOL;   // 占位符: 向组框机请求输送边框
    q_b组框机_暂停          : BOOL;   // 占位符: 向组框机发送暂停指令
    q_b组框机_急停          : BOOL;   // 占位符: 向组框机发送急停联锁信号
    q_b申请开门             : BOOL;   // 占位符: 向组框机申请开门操作
    q_b组框机_就绪          : BOOL;   // 占位符: 本机就绪, 可接收边框


    (* ========================================================================== *)
    (* 七、HMI数据 - 输入 (M/D区读取 -> 逻辑变量)                                *)
    (* 注: 具体M/D地址需根据HMI画面分配表确定, 此处使用占位符                     *)
    (* ========================================================================== *)

    (*--- 模式选择 (互斥信号) ---*)
    bHMI_自动模式       : BOOL;   // M?  (自动运行模式选择)
    bHMI_手动模式       : BOOL;   // M?  (手动调试模式选择)

    (*--- 操作按钮 ---*)
    bHMI_启动           : BOOL;   // M?  (启动按钮, 上升沿触发)
    bHMI_停止           : BOOL;   // M?  (停止按钮, 电平有效)
    bHMI_复位           : BOOL;   // M?  (复位按钮, 电平有效)

    (*--- 工艺参数设定 (REAL类型) ---*)
    rHMI_输送速度设定    : REAL;   // D?  (输送带速度设定 Hz或m/min)
    rHMI_伺服速度设定    : REAL;   // D?  (伺服轴速度设定 mm/s或%)
    rHMI_取料速度设定    : REAL;   // D?  (取料过程速度 mm/s)
    rHMI_放料速度设定    : REAL;   // D?  (放料过程速度 mm/s)

    (*--- 动作时间参数设定 (INT类型, 单位ms) ---*)
    iHMI_分料时间设定    : INT;    // D?  (分料动作保持时间)
    iHMI_夹紧确认时间设定 : INT;   // D?  (夹爪夹紧确认等待时间)
    iHMI_升降动作时间设定 : INT;   // D?  (升降气缸动作超时时间)


    (* ========================================================================== *)
    (* 八、HMI数据 - 输出 (逻辑变量 -> M/D区回写)                                *)
    (* ========================================================================== *)

    (*--- 系统状态显示 ---*)
    bHMI_系统运行中      : BOOL;   // -> M?  (系统正在自动运行)
    bHMI_系统故障        : BOOL;   // -> M?  (系统有故障)
    bHMI_系统就绪        : BOOL;   // -> M?  (系统初始化完成, 可启动)

    (*--- 各工站运行状态 ---*)
    bHMI_输送机运行中    : BOOL;   // -> M?  (四层输送机运行中)
    bHMI_取放料运行中    : BOOL;   // -> M?  (取放料机构运行中)
    bHMI_送料机构运行中  : BOOL;   // -> M?  (打胶机送料机构运行中)

    (*--- 报警信息显示 ---*)
    iHMI_全局报警代码    : INT;    // -> D?  (当前最高优先级报警码)
    wHMI_全局报警字      : WORD;   // -> D?  (全局报警字, 位或组合)
    bHMI_任何报警激活    : BOOL;   // -> M?  (是否有任何报警激活)

    (*--- 取放料位置显示 ---*)
    iHMI_当前取料层数    : INT;    // -> D?  (当前正在处理的层数 0~4)
    iHMI_取放料步序      : INT;    // -> D?  (取放料状态机步序 0~10)


    (* ========================================================================== *)
    (* 九、中间变量 (用于工站间信号传递和内部计算)                               *)
    (* ========================================================================== *)

    (*--- 下游信号传递 (工站间的协调信号) ---*)
