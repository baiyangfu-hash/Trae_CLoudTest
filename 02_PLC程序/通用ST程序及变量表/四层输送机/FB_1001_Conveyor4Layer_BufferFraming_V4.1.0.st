(* ============================================================================
 功能块名称: FB_1001_Conveyor4Layer_BufferFraming
 功能描述: 边框缓存机 - 四层输送机容器功能块(纯容器,无业务逻辑)
 ============================================================================ *)
(*
 * 项目: DJ-2026-005 边框缓存机
 * 版本: V4.1.0
 * 创建日期: 2026-04-23
 * 规范化修订日期: 2026-04-25
 * 编制人: [待填写]
 * 审核人: [待填写]
 *
 * 遵循规范:
 *   - 801_PLC变量命名与功能块命名规范_DEV-V1.0.5
 *   - 810_PLC编程规范_DEV-V1.0.3
 *
 * 说明: 容器功能块 - 四层输送机控制(纯容器,无业务逻辑)
 *       内部实例化4个 FB_1002_SingleLayerConveyor_BufferFraming,负责输入分发和输出收集
 *       所有输入来自主控(已映射的逻辑变量), 所有输出给主控(由主控映射到Y地址)
 *
 * 功能:
 *   1. 容器模式: 内部实例化4个独立 FB_1002_SingleLayerConveyor_BufferFraming
 *   2. 输入分发: 将ARRAY输入拆分为单个信号,分别传给各层实例
 *   3. 输出收集: 将4个实例的输出汇聚为ARRAY,供主控读取
 *   4. 状态汇总: 运行中/故障/报警码的汇总逻辑
 *   5. 完全解耦: 无业务逻辑,仅做信号路由和数据聚合
 *
 * 架构特点:
 *   - 纯容器块: 不包含任何业务逻辑或状态机
 *   - 实例化设计: 4个独立的 FB_1002_SingleLayerConveyor_BufferFraming 实例
 *   - 接口兼容: 外部接口保持ARRAY[1..4]形式,与原版本完全兼容
 *   - 职责单一: 只做输入分发→调用实例→输出收集
 *   - 可维护性: 业务逻辑全部在 FB_1002_SingleLayerConveyor_BufferFraming 中,此处只做路由
 *
 * 调用关系:
 *   主控/HMI → [FB_1001_Conveyor4Layer_BufferFraming (容器)] → [fbLayer1~4: FB_1002_SingleLayerConveyor_BufferFraming]
 *                    ↓ 输入分发                    ↑ 输出收集
 *               ARRAY[1..4] → 4个单实例        4个单实例 → ARRAY[1..4]
 *
 * #region 编号规范:
 *   1xx = VAR_INPUT 变量组  |  2xx = VAR_OUTPUT 变量组  |  3xx = VAR 内部变量组
 *   8xx = 输入分发逻辑     |  4xx = 调用/自动运行       |  9xx = 输出收集逻辑
 *
 * 变更记录:
 *   V4.1.0 (2026-04-25): 规范化修订
 *          - 文件头格式统一为标准(* *)块注释格式
 *          - 注释风格统一: 段落分隔符改为(* ============ *)格式
 *          - 规范引用更新至最新版本号(V1.0.5/V1.0.3)
 *          - 新增 #region 折叠导航标记(编号体系)
 *          - 代码逻辑和变量名保持不变
 *   V4.0.0 (2026-04-23): 初始版本(容器模式重写)
 *          - 采用容器模式重写四层输送机控制
 *          - 内部实例化4个单层输送机功能块
 *          - 实现输入分发和输出收集的纯路由逻辑
 *)

FUNCTION_BLOCK FB_1001_Conveyor4Layer_BufferFraming

//#region 100_VAR_INPUT 输入变量定义
VAR_INPUT
    //#region 110_系统控制信号 来自主控HMI公共透传
    (*==========================================================================
      一、系统控制信号 (来自主控/HMI M区) - 公共信号,透传给所有层
      ==========================================================================*)
    i_b使能               : BOOL;    // 总使能信号(主控系统就绪后置位)

    (*-------------------------------------------------------------------------
      模式选择 (互斥信号,来自HMI M区)
      -------------------------------------------------------------------------*)
    i_b自动模式           : BOOL;    // 自动运行模式选择
    i_b手动模式           : BOOL;    // 手动调试模式选择

    (*-------------------------------------------------------------------------
      操作按钮 (来自HMI,边沿触发)
      -------------------------------------------------------------------------*)
    i_b启动               : BOOL;    // 自动循环启动按钮
    i_b停止               : BOOL;    // 自动循环停止按钮
    i_b复位               : BOOL;    // 故障复位/初始化按钮
    //#endregion 110_系统控制信号

    //#region 120_工艺参数 来自HMI设定或配方
    (*==========================================================================
      二、工艺参数 (来自HMI设定或配方) - 公共参数,透传给所有层
      ==========================================================================*)
    i_r输送速度           : REAL;    // 输送带速度设定(Hz或m/min,给变频器用)
    i_i分料时间           : INT;     // 分料动作保持时间(ms)
    i_i阻挡等待时间        : INT;     // 阻挡气缸动作等待时间(ms)
    //#endregion 120_工艺参数

    //#region 130_手动操作信号 每层6个操作共24个BOOL
    (*==========================================================================
      三、手动操作信号 (每层6个操作,共24个BOOL,来自HMI)
      索引说明: [1]=第1层(底层), [2]=第2层, [3]=第3层, [4]=第4层(顶层)
      ==========================================================================*)
    i_b阻挡下降           : ARRAY[1..4] OF BOOL;  // 手动-阻挡气缸下降
    i_b阻挡上升           : ARRAY[1..4] OF BOOL;  // 手动-阻挡气缸上升
    i_b分料推出           : ARRAY[1..4] OF BOOL;  // 手动-分料气缸推出
    i_b分料复位           : ARRAY[1..4] OF BOOL;  // 手动-分料气缸复位
    i_b输送正转           : ARRAY[1..4] OF BOOL;  // 手动-输送带正转
    i_b输送反转           : ARRAY[1..4] OF BOOL;  // 手动-输送带反转
    //#endregion 130_手动操作信号

    //#region 140_传感器输入 4层x7类28个BOOL全部来自主控映射
    (*==========================================================================
      四、传感器输入 (4层×7类=28个BOOL,全部来自主控映射)
      注: 放料完成感应器通过下游信号o_b放料完成反馈
      ==========================================================================*)
    (*--- 分料前感应器: 检测材料是否到达分料工位入口 ---*)
    i_b分料前感应器         : ARRAY[1..4] OF BOOL;

    (*--- 到位感应器1/2: 双传感器冗余检测材料到位 ---*)
    i_b到位感应器1          : ARRAY[1..4] OF BOOL;
    i_b到位感应器2          : ARRAY[1..4] OF BOOL;

    (*--- 阻挡气缸位置反馈 ---*)
    i_b阻挡气缸上位         : ARRAY[1..4] OF BOOL;  // 阻挡升起(释放)位置
    i_b阻挡气缸下位         : ARRAY[1..4] OF BOOL;  // 阻挡下降(阻挡)位置

    (*--- 分料气缸位置反馈 ---*)
    i_b分料气缸上位         : ARRAY[1..4] OF BOOL;  // 分料收回位置
    i_b分料气缸下位         : ARRAY[1..4] OF BOOL;  // 分料推出位置
    //#endregion 140_传感器输入

    //#region 150_下游反馈信号 取放料机构已取走该层物料
    (*==========================================================================
      五、下游反馈信号 (取放料机构已取走该层物料)
      映射关系: 此信号 → 各层实例的 i_b上游允许放料
      ==========================================================================*)
    i_b取放料完成          : ARRAY[1..4] OF BOOL;  // 取放料机构已取走该层物料
    //#endregion 150_下游反馈信号
END_VAR
//#endregion 100_VAR_INPUT


//#region 200_VAR_OUTPUT 输出变量定义
VAR_OUTPUT
    //#region 210_执行器请求输出 4层x5=20个BOOL全部给主控由主控映射到Y地址
    (*==========================================================================
      一、执行器请求输出 (4层×5=20个BOOL,全部给主控,由主控映射到Y地址)
      ==========================================================================*)
    o_b阻挡电磁阀           : ARRAY[1..4] OF BOOL;  // TRUE=下降(阻挡), FALSE=上升(释放)
    o_b分料电磁阀           : ARRAY[1..4] OF BOOL;  // TRUE=推出(分料), FALSE=复位
    o_b输送带正转           : ARRAY[1..4] OF BOOL;  // 输送带正向运转
    o_b输送带慢速           : ARRAY[1..4] OF BOOL;  // 输送带慢速运转(精确定位用)
    o_b输送带反转           : ARRAY[1..4] OF BOOL;  // 输送带反向运转(退料用)
    //#endregion 210_执行器请求输出

    //#region 220_下游信号输出 给取放料机构和打胶机
    (*==========================================================================
      二、下游信号输出 (给取放料机构/打胶机)
      ==========================================================================*)
    o_b放料完成            : ARRAY[1..4] OF BOOL;  // 该层放料完成,可取料
    //#endregion 220_下游信号输出

    //#region 230_状态与HMI显示输出
    (*==========================================================================
      三、状态/HMI显示输出
      ==========================================================================*)
    o_b运行中              : BOOL;    // 任一层正在自动运行
    o_b故障                : BOOL;    // 本站有故障(任一报警激活)
    o_i当前状态            : INT;     // 当前主要状态码(0=空闲,1-8=步序,99=故障)
    o_Lx当前步序           : ARRAY[1..4] OF INT;   // 每层当前步序(0-8)
    //#endregion 230_状态与HMI显示输出

    //#region 240_报警输出 给公共报警管理器
    (*==========================================================================
      四、报警输出 (给公共报警管理器)
      ==========================================================================*)
    o_i本站报警代码        : INT;     // 本站当前有效报警代码(0=无报警,1-7=报警类型)
    //#endregion 240_报警输出
END_VAR
//#endregion 200_VAR_OUTPUT


//#region 300_VAR 内部变量定义
(*==============================================================================
 内部变量定义 (容器专用: 4个单层实例 + 汇总辅助变量)
 ==============================================================================*)
VAR
    //#region 310_4个单层输送机实例 核心业务逻辑在此
    (*--------------------------------------------------------------------------
      一、4个单层输送机实例 (核心: 所有业务逻辑在此)
      --------------------------------------------------------------------------*)
    fbLayer1 : FB_1002_SingleLayerConveyor_BufferFraming;  // 第1层(底层)
    fbLayer2 : FB_1002_SingleLayerConveyor_BufferFraming;  // 第2层
    fbLayer3 : FB_1002_SingleLayerConveyor_BufferFraming;  // 第3层
    fbLayer4 : FB_1002_SingleLayerConveyor_BufferFraming;  // 第4层(顶层)
    //#endregion 310_4个单层输送机实例

    //#region 320_汇总辅助变量 用于输出收集
    (*--------------------------------------------------------------------------
      二、汇总辅助变量 (用于输出收集)
      --------------------------------------------------------------------------*)
    s_i活跃报警             : INT;     // 当前最高优先级报警代码(临时计算用)
    s_iLayerIdx             : INT;     // FOR循环索引(层号1-4)
    //#endregion 320_汇总辅助变量
END_VAR
//#endregion 300_VAR


(*==============================================================================
 主程序开始 - 容器逻辑: 输入分发 → 调用实例 → 输出收集
 ==============================================================================*)

//#region 800_第一部分 输入分发 将公共信号和每层独立信号分配到4个实例
(* ============================================================================
 第一部分: 输入分发 - 将公共信号和每层独立信号分配到4个实例
 ============================================================================ *)

//#region 810_公共信号分发 使能模式启停参数 所有4个实例相同
(*------------------------------------------------------------------------------
  1.1 公共信号分发 (使能/模式/启停/参数) → 所有4个实例相同
 ------------------------------------------------------------------------------*)

(*--- 第1层公共信号 ---*)
fbLayer1.i_b使能         := i_b使能;
fbLayer1.i_b自动模式     := i_b自动模式;
fbLayer1.i_b手动模式     := i_b手动模式;
fbLayer1.i_b启动         := i_b启动;
fbLayer1.i_b停止         := i_b停止;
fbLayer1.i_b复位         := i_b复位;
fbLayer1.i_r输送速度     := i_r输送速度;
fbLayer1.i_i分料时间     := i_i分料时间;
fbLayer1.i_i阻挡等待时间  := i_i阻挡等待时间;

(*--- 第2层公共信号 ---*)
fbLayer2.i_b使能         := i_b使能;
fbLayer2.i_b自动模式     := i_b自动模式;
fbLayer2.i_b手动模式     := i_b手动模式;
fbLayer2.i_b启动         := i_b启动;
fbLayer2.i_b停止         := i_b停止;
fbLayer2.i_b复位         := i_b复位;
fbLayer2.i_r输送速度     := i_r输送速度;
fbLayer2.i_i分料时间     := i_i分料时间;
fbLayer2.i_i阻挡等待时间  := i_i阻挡等待时间;

(*--- 第3层公共信号 ---*)
fbLayer3.i_b使能         := i_b使能;
fbLayer3.i_b自动模式     := i_b自动模式;
fbLayer3.i_b手动模式     := i_b手动模式;
fbLayer3.i_b启动         := i_b启动;
fbLayer3.i_b停止         := i_b停止;
fbLayer3.i_b复位         := i_b复位;
fbLayer3.i_r输送速度     := i_r输送速度;
fbLayer3.i_i分料时间     := i_i分料时间;
fbLayer3.i_i阻挡等待时间  := i_i阻挡等待时间;

(*--- 第4层公共信号 ---*)
fbLayer4.i_b使能         := i_b使能;
fbLayer4.i_b自动模式     := i_b自动模式;
fbLayer4.i_b手动模式     := i_b手动模式;
fbLayer4.i_b启动         := i_b启动;
fbLayer4.i_b停止         := i_b停止;
fbLayer4.i_b复位         := i_b复位;
fbLayer4.i_r输送速度     := i_r输送速度;
fbLayer4.i_i分料时间     := i_i分料时间;
fbLayer4.i_i阻挡等待时间  := i_i阻挡等待时间;
//#endregion 810_公共信号分发


//#region 820_手动操作信号分发 6类x4层 每层的独立手动操作
(*------------------------------------------------------------------------------
  1.2 手动操作信号分发 (6类×4层) → 每层的独立手动操作
 ------------------------------------------------------------------------------*)

(*--- 第1层手动操作 ---*)
fbLayer1.i_b阻挡下降     := i_b阻挡下降[1];
fbLayer1.i_b阻挡上升     := i_b阻挡上升[1];
fbLayer1.i_b分料推出     := i_b分料推出[1];
fbLayer1.i_b分料复位     := i_b分料复位[1];
fbLayer1.i_b输送正转     := i_b输送正转[1];
fbLayer1.i_b输送反转     := i_b输送反转[1];

(*--- 第2层手动操作 ---*)
fbLayer2.i_b阻挡下降     := i_b阻挡下降[2];
fbLayer2.i_b阻挡上升     := i_b阻挡上升[2];
fbLayer2.i_b分料推出     := i_b分料推出[2];
fbLayer2.i_b分料复位     := i_b分料复位[2];
fbLayer2.i_b输送正转     := i_b输送正转[2];
fbLayer2.i_b输送反转     := i_b输送反转[2];

(*--- 第3层手动操作 ---*)
fbLayer3.i_b阻挡下降     := i_b阻挡下降[3];
fbLayer3.i_b阻挡上升     := i_b阻挡上升[3];
fbLayer3.i_b分料推出     := i_b分料推出[3];
fbLayer3.i_b分料复位     := i_b分料复位[3];
fbLayer3.i_b输送正转     := i_b输送正转[3];
fbLayer3.i_b输送反转     := i_b输送反转[3];

(*--- 第4层手动操作 ---*)
fbLayer4.i_b阻挡下降     := i_b阻挡下降[4];
fbLayer4.i_b阻挡上升     := i_b阻挡上升[4];
fbLayer4.i_b分料推出     := i_b分料推出[4];
fbLayer4.i_b分料复位     := i_b分料复位[4];
fbLayer4.i_b输送正转     := i_b输送正转[4];
fbLayer4.i_b输送反转     := i_b输送反转[4];
//#endregion 820_手动操作信号分发


//#region 830_传感器信号分发 7类x4层 每层的独立传感器输入
(*------------------------------------------------------------------------------
  1.3 传感器信号分发 (7类×4层) → 每层的独立传感器输入
 ------------------------------------------------------------------------------*)

(*--- 第1层传感器 ---*)
fbLayer1.i_b分料前感应器   := i_b分料前感应器[1];
fbLayer1.i_b到位感应器1    := i_b到位感应器1[1];
fbLayer1.i_b到位感应器2    := i_b到位感应器2[1];
fbLayer1.i_b阻挡气缸上位   := i_b阻挡气缸上位[1];
fbLayer1.i_b阻挡气缸下位   := i_b阻挡气缸下位[1];
fbLayer1.i_b分料气缸上位   := i_b分料气缸上位[1];
fbLayer1.i_b分料气缸下位   := i_b分料气缸下位[1];

(*--- 第2层传感器 ---*)
fbLayer2.i_b分料前感应器   := i_b分料前感应器[2];
fbLayer2.i_b到位感应器1    := i_b到位感应器1[2];
fbLayer2.i_b到位感应器2    := i_b到位感应器2[2];
fbLayer2.i_b阻挡气缸上位   := i_b阻挡气缸上位[2];
fbLayer2.i_b阻挡气缸下位   := i_b阻挡气缸下位[2];
fbLayer2.i_b分料气缸上位   := i_b分料气缸上位[2];
fbLayer2.i_b分料气缸下位   := i_b分料气缸下位[2];

(*--- 第3层传感器 ---*)
fbLayer3.i_b分料前感应器   := i_b分料前感应器[3];
fbLayer3.i_b到位感应器1    := i_b到位感应器1[3];
fbLayer3.i_b到位感应器2    := i_b到位感应器2[3];
fbLayer3.i_b阻挡气缸上位   := i_b阻挡气缸上位[3];
fbLayer3.i_b阻挡气缸下位   := i_b阻挡气缸下位[3];
fbLayer3.i_b分料气缸上位   := i_b分料气缸上位[3];
fbLayer3.i_b分料气缸下位   := i_b分料气缸下位[3];

(*--- 第4层传感器 ---*)
fbLayer4.i_b分料前感应器   := i_b分料前感应器[4];
fbLayer4.i_b到位感应器1    := i_b到位感应器1[4];
fbLayer4.i_b到位感应器2    := i_b到位感应器2[4];
fbLayer4.i_b阻挡气缸上位   := i_b阻挡气缸上位[4];
fbLayer4.i_b阻挡气缸下位   := i_b阻挡气缸下位[4];
fbLayer4.i_b分料气缸上位   := i_b分料气缸上位[4];
fbLayer4.i_b分料气缸下位   := i_b分料气缸下位[4];
//#endregion 830_传感器信号分发


//#region 840_下游反馈信号分发 取放料完成到上游允许放料
(*------------------------------------------------------------------------------
  1.4 下游反馈信号分发 (取放料完成 → 上游允许放料)
  映射关系: i_b取放料完成[层号] → fbLayerX.i_b上游允许放料
  说明: 取放料机构已取走该层物料后,允许该层继续放下一批料
 ------------------------------------------------------------------------------*)

fbLayer1.i_b上游允许放料 := i_b取放料完成[1];
fbLayer2.i_b上游允许放料 := i_b取放料完成[2];
fbLayer3.i_b上游允许放料 := i_b取放料完成[3];
fbLayer4.i_b上游允许放料 := i_b取放料完成[4];
//#endregion 840_下游反馈信号分发
//#endregion 800_第一部分 输入分发


//#region 410_第二部分 调用4个单层实例 执行业务逻辑
(* ============================================================================
 第二部分: 调用4个单层实例 (执行业务逻辑)
 注意: FB_1002_SingleLayerConveyor_BufferFraming 是完整的功能块,赋值输入后会自动执行内部逻辑
 ============================================================================ *)

