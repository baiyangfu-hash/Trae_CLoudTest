//#region 940_汇总状态输出 运行中故障当前状态报警码
(*------------------------------------------------------------------------------
  3.4 汇总状态输出 (运行中/故障/当前状态/报警码)
 -----------------------------------------------------------------------------*)

(*--- 运行中标志: 任一层在自动运行则TRUE ---*)
o_b运行中 := fbLayer1.o_b运行中 OR fbLayer2.o_b运行中
          OR fbLayer3.o_b运行中 OR fbLayer4.o_b运行中;

(*--- 故障标志: 任一层有故障则TRUE ---*)
o_b故障 := fbLayer1.o_b故障 OR fbLayer2.o_b故障
         OR fbLayer3.o_b故障 OR fbLayer4.o_b故障;

(*--- 当前状态显示优先级:
     1. 如果任一有故障 → 返回99
     2. 否则返回第一个非空闲层的步序
     3. 全部空闲则返回0
 ---*)
IF o_b故障 THEN
    (* 有故障: 显示故障状态码99 *)
    o_i当前状态 := 99;
ELSE
    (* 无故障: 显示最高优先级(最先找到)的非空闲层步序 *)
    o_i当前状态 := 0;  (* 默认空闲 *)
    IF fbLayer1.o_i当前状态 > 0 THEN
        o_i当前状态 := fbLayer1.o_i当前状态;
    ELSIF fbLayer2.o_i当前状态 > 0 THEN
        o_i当前状态 := fbLayer2.o_i当前状态;
    ELSIF fbLayer3.o_i当前状态 > 0 THEN
        o_i当前状态 := fbLayer3.o_i当前状态;
    ELSIF fbLayer4.o_i当前状态 > 0 THEN
        o_i当前状态 := fbLayer4.o_i当前状态;
    END_IF;
END_IF;

(*--- 本站报警代码: 取最高优先级(最小编号)的非零报警码
     报警优先级: 1>2>3>4>5>6>7 (数字越小优先级越高)
 ---*)
s_i活跃报警 := 0;  (* 初始化为无报警 *)

(* 第1层报警检查 *)
IF fbLayer1.o_i报警代码 > 0 THEN
    IF s_i活跃报警 = 0 OR fbLayer1.o_i报警代码 < s_i活跃报警 THEN
        s_i活跃报警 := fbLayer1.o_i报警代码;
    END_IF;
END_IF;

(* 第2层报警检查 *)
IF fbLayer2.o_i报警代码 > 0 THEN
    IF s_i活跃报警 = 0 OR fbLayer2.o_i报警代码 < s_i活跃报警 THEN
        s_i活跃报警 := fbLayer2.o_i报警代码;
    END_IF;
END_IF;

(* 第3层报警检查 *)
IF fbLayer3.o_i报警代码 > 0 THEN
    IF s_i活跃报警 = 0 OR fbLayer3.o_i报警代码 < s_i活跃报警 THEN
        s_i活跃报警 := fbLayer3.o_i报警代码;
    END_IF;
END_IF;

(* 第4层报警检查 *)
IF fbLayer4.o_i报警代码 > 0 THEN
    IF s_i活跃报警 = 0 OR fbLayer4.o_i报警代码 < s_i活跃报警 THEN
        s_i活跃报警 := fbLayer4.o_i报警代码;
    END_IF;
END_IF;

(* 输出最终报警代码 *)
o_i本站报警代码 := s_i活跃报警;
