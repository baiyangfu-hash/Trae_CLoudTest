(* ============================================================================
 功能块名称: FB_1004_GlueMachineFeeder_BufferFraming
 功能描述: 边框缓存机 - 打胶机送料机构纯逻辑功能块(不包含任何X/Y/M/D地址引用)
 ============================================================================ *)
(*
 * 项目: DJ-2026-005 边框缓存机
 * 版本: V4.1.0
 * 创建日期: 2026-04-23
 * 规范化修订日期: 2026-04-25
 * 编制人: [待填写]
 * 审核人: [待填写]
 *
 * 遵循规范:
 *   - 801_PLC变量命名与功能块命名规范_DEV-V1.0.5
 *   - 810_PLC编程规范_DEV-V1.0.3
 *
 * 说明: 纯逻辑功能块 - 打胶机送料机构独立控制(不包含任何X/Y/M/D地址引用)
 *       所有输入来自主控(已映射的逻辑变量), 所有输出给主控(由主控映射到Y地址)
 *
 * 核心工艺:
 *   接收取放料机构的放料完成信号后, X2轴移动到打胶机取料位置
 *   等待打胶机允许送料 -> 发送允许抓料信号 -> 等待打胶机取料完成
 *   返回待机位置, 循环执行
 *
 * 架构特点:
 *   - 纯逻辑块: 不包含任何X/Y/M/D地址引用
 *   - 数据解耦: 通过逻辑变量接口与主控交互
 *   - 6步状态机: 完整的自动送料循环控制
 *   - 故障安全: 内置超时保护、伺服故障检测、安全区冲突检测
 *   - 安全区管理: 与取放料机构的区域互锁, 防止机械碰撞
 *   - 完全自包含, 无外部物理地址依赖
 *
 * 功能:
 *   1. 自动模式状态机(6步完整送料循环)
 *   2. 手动模式控制(X2轴点动前/后)
 *   3. 初始化流程(伺服使能、状态清零)
 *   4. 块内报警检测与处理(5种报警类型, 201~299段)
 *   5. 安全区逻辑(与取放料机构的区域互锁)
 *   6. 完全自包含, 无外部物理地址依赖
 *
 * 变更记录:
 *   V4.1.0 (2026-04-25): 规范化修订
 *          - 文件头格式统一为标准(* *)块注释格式
 *          - 注释风格统一: 段落分隔符改为(* ============ *)格式
 *          - 规范引用更新至最新版本号(V1.0.5/V1.0.3)
 *          - 代码逻辑和变量名保持不变
 *   V4.0.0 (2026-04-23): 初始版本
 *          - 实现打胶机送料机构完整控制逻辑
 *          - 6步状态机实现自动送料循环
 *          - 支持安全区管理和手动操作
 *)

FUNCTION_BLOCK FB_1004_GlueMachineFeeder_BufferFraming

VAR_INPUT
    (*==========================================================================
      一、系统控制信号 (来自主控/HMI M区)
      ==========================================================================*)
    i_b使能               : BOOL;    // 总使能信号(主控系统就绪后置位)

    (*-------------------------------------------------------------------------
      模式选择 (互斥信号,来自HMI M区)
      -------------------------------------------------------------------------*)
    i_b自动模式           : BOOL;    // 自动运行模式选择
    i_b手动模式           : BOOL;    // 手动调试模式选择

    (*-------------------------------------------------------------------------
      操作按钮 (来自HMI,边沿触发或电平有效)
      -------------------------------------------------------------------------*)
    i_b启动               : BOOL;    // 自动循环启动按钮(上升沿触发)
    i_b停止               : BOOL;    // 自动循环停止按钮(电平有效)
    i_b复位               : BOOL;    // 故障复位/初始化按钮(电平有效)

    (*==========================================================================
      二、手动操作信号 (2个BOOL,来自HMI)
      注: 本功能块仅控制X2轴(打胶机送料方向的水平轴)
      ==========================================================================*)
    (*--- X2轴伺服点动控制 (2个) ---*)
    i_bX2轴点动前         : BOOL;    // 手动-X2轴向前点动(去打胶机取料位置方向)
    i_bX2轴点动后         : BOOL;    // 手动-X2轴向后点动(返回待机位置方向)

    (*==========================================================================
      三、工艺参数 (来自HMI设定或配方, REAL类型)
      ==========================================================================*)
    i_r送料速度           : REAL;    // X2轴送料运动速度(mm/s或%)
    i_r待机位置           : REAL;    // X2轴待机位置坐标(mm, 安全等待位置)
    i_r取料位置           : REAL;    // X2轴取料位置坐标(mm, 打胶机取料口位置)

    (*==========================================================================
      四、传感器输入 (4个BOOL,全部来自主控IO映射)
      注: 本功能块不直接读取X地址, 所有传感器由主控映射后传入
      仅涉及X2轴相关传感器
      ==========================================================================*)
    (*--- X2轴伺服状态信号 ---*)
    i_bX2轴_原点           : BOOL;    // X2轴伺服原点信号(Home/ORG)
    i_bX2轴_正向限位       : BOOL;    // X2轴正向限位(去打胶机侧限位)
    i_bX2轴_反向限位       : BOOL;    // X2轴反向限位(待机位侧限位)
    i_bX2轴_伺服故障       : BOOL;    // X2轴伺服驱动器故障(ALM输出)

    (*==========================================================================
      五、打胶机交互信号 (2个BOOL,已由主控做IO映射)
      注: 这些是来自外部打胶机的硬接线信号, 由主控完成IO映射
      ==========================================================================*)
    i_b打胶机允许送料     : BOOL;    // 打胶机允许送料信号(对应物理地址X76)
                                    // TRUE=打胶机准备好可以接收边框
    i_b打胶机取料完成     : BOOL;    // 打胶机取料完成信号(对应物理地址X102)
                                    // TRUE=打胶机已完成边框抓取

    (*==========================================================================
      六、上游信号 (1个BOOL,来自取放料机构)
      ==========================================================================*)
    i_b取放料_放料完成    : BOOL;    // 取放料机构放料完成信号
                                    // TRUE=取放料机构已完成放料并移出安全区
END_VAR


VAR_OUTPUT
    (*==========================================================================
      一、执行器请求输出 (给主控, 由主控映射到Y地址)
      ==========================================================================*)

    (*--- 给打胶机的输出信号 ---*)
    o_b允许抓料            : BOOL;    // 允许抓料信号 -> 主控映射到Y44
                                    // 通知打胶机可以抓取边框(本站已到位且准备好)

    (*--- X2轴运动请求输出 (给主控驱动脉冲输出) ---*)
    o_bX2轴请求前移       : BOOL;    // X2轴向前移动请求(去打胶机取料位置)
    o_bX2轴请求后移       : BOOL;    // X2轴向后移动请求(返回待机位置)

    (*--- 安全区管理信号 ---*)
    o_b安全区信号          : BOOL;    // 安全区信号 -> 主控映射到Y47
                                    // TRUE=取放料机构在安全区外(打胶机可进入)
                                    // FALSE=取放料机构在工作区(禁止打胶机进入)

    (*==========================================================================
      二、状态/HMI显示输出
      ==========================================================================*)
    o_b运行中             : BOOL;    // 本站正在自动运行
    o_b故障               : BOOL;    // 本站有故障(任一报警激活)
    o_i当前状态           : INT;     // 当前状态机步序(0~5, 99=故障)
    o_rX2轴当前位置       : REAL;    // X2轴当前位置反馈(mm, 来自主控映射)

    (*==========================================================================
      三、报警输出 (给公共报警管理器)
      ==========================================================================*)
    o_i本站报警代码       : INT;     // 本站当前有效报警代码(0=无报警, 201~299=报警类型)
END_VAR


(*==============================================================================
 内部变量定义
 ==============================================================================*)
VAR
    (*--------------------------------------------------------------------------
      一、状态机核心变量
      --------------------------------------------------------------------------*)
    s_i步序               : INT;     // 当前状态机步序(0~5)
    s_b运行中             : BOOL;    // 自动运行中标志
    s_b故障               : BOOL;    // 故障标志
    s_b启动触发           : BOOL;    // 启动信号锁存(防重复触发)

    (*--- X2轴运动请求标志 (给主控处理脉冲输出) ---*)
    s_bX2轴请求前移       : BOOL;    // X2轴向前移动请求(去取料位置)
    s_bX2轴请求后移       : BOOL;    // X2轴向后移动请求(返回待机位置)
    s_bX2轴在待机位       : BOOL;    // X2轴是否在待机位置标志(由主控反馈)
    s_bX2轴在取料位       : BOOL;    // X2轴是否在取料位置标志(由主控反馈)

    (*--- 安全区管理变量 ---*)
    s_b取放料曾工作      : BOOL;    // 取放料机构曾经工作过标志(用于安全区判断)
    s_b上次放料完成      : BOOL;    // 上次扫描周期的放料完成状态(用于上升沿检测)

    (*--- 打胶机通讯超时检测 ---*)
    s_t通讯超时定时器     : TON;     // 打胶机响应超时检测定时器
    s_b等待打胶机响应     : BOOL;    // 正在等待打胶机响应标志

    (*--------------------------------------------------------------------------
      二、定时器 (覆盖所有时序需求)
      --------------------------------------------------------------------------*)
    s_t动作定时器         : TON;     // 通用动作等待定时器(X2轴移动等)
    s_t初始化定时器       : TON;     // 初始化总超时定时器
    s_t抓料保持定时器     : TON;     // 允许抓料信号保持定时器

    (*--------------------------------------------------------------------------
      三、系统级内部变量
      --------------------------------------------------------------------------*)
    s_b初始化完成         : BOOL;    // 上电初始化完成标志
    s_b初始化中           : BOOL;    // 正在执行初始化

    (*--- 报警相关 ---*)
    s_i活跃报警           : INT;     // 当前最高优先级报警代码

    (*--- 手动操作互锁 ---*)
    s_b手动允许           : BOOL;    // 允许手动操作标志
END_VAR


(*==============================================================================
 常量定义 (状态机步序 + 报警码 + 定时参数)
 ==============================================================================*)
VAR CONSTANT
    (*--------------------------------------------------------------------------
      状态机步序常量 (6步: 0空闲 + 5工作步)
      核心工艺: 接收放料完成 -> 移动到取料位 -> 等待允许 -> 抓料 -> 返回待机
      --------------------------------------------------------------------------*)
    STP_空闲              : INT := 0;   // 空闲/待机位置
    STP_等待放料完成      : INT := 1;   // 等待取放料机构放料完成
    STP_移动到取料位置    : INT := 2;   // X2轴移动到打胶机取料位置
    STP_等待允许送料      : INT := 3;   // 等待打胶机允许送料信号
    STP_发送允许抓料      : INT := 4;   // 发送允许抓料+等待打胶机取料完成
    STP_返回待机位置      : INT := 5;   // X2轴返回待机位置

    (*--------------------------------------------------------------------------
      报警码常量 (201~299段, 0=无报警)
      与取放料机构(101~199段)、其他设备错开, 便于公共报警管理器区分来源
      --------------------------------------------------------------------------*)
    ALM_通讯超时          : INT := 201;  // 通讯超时(打胶机无响应)
    ALM_安全区冲突        : INT := 202;  // 安全区冲突(取放料未离开)
    ALM_X2轴伺服故障      : INT := 203;  // X2轴伺服驱动器故障
    ALM_X2轴移动超时      : INT := 204;  // X2轴移动超时(未到达目标位置)
    ALM_取料位置到达超时  : INT := 205;  // 取料位置到达超时(步骤2专用)

    (*--------------------------------------------------------------------------
      默认定时参数 (单位: ms 或 s, 可通过输入参数覆盖)
      --------------------------------------------------------------------------*)
    T_DEF_移动超时时间    : INT := 5000;    // X2轴移动超时保护(5s)
    T_DEF_通讯超时时间    : INT := 10000;   // 打胶机响应超时(10s)
    T_DEF_抓料保持时间    : INT := 500;     // 允许抓料信号保持时间(500ms)
    T_DEF_初始化超时      : INT := 10000;   // 初始化总超时(10s)
END_VAR


(*==============================================================================
 主程序开始
 ==============================================================================*)

(* ============================================================================
 第一部分: 使能与初始化处理
 ============================================================================ *)

(*--- 使能失效时的安全处理: 全部输出归零, 状态复位 ---*)
IF NOT i_b使能 THEN
    (
    (* 清零所有执行器输出 *)
    o_b允许抓料            := FALSE;
    o_b安全区信号          := FALSE;
    o_bX2轴请求前移       := FALSE;
    o_bX2轴请求后移       := FALSE;

    (* 清零所有状态 *)
    s_i步序               := STP_空闲
    s_b运行中             := FALSE;
    s_b故障               := FALSE;
    s_b启动触发           := FALSE;

    (* 清零运动请求 *)
    s_bX2轴请求前移       := FALSE;
    s_bX2轴请求后移       := FALSE;
    s_bX2轴在待机位       := FALSE;
    s_bX2轴在取料位       := FALSE;

    (* 清零安全区变量 *)
    s_b取放料曾工作      := FALSE;
    s_b上次放料完成      := FALSE;
    s_b等待打胶机响应     := FALSE;

    (* 清零报警 *)
    s_i活跃报警           := 0;
    o_i本站报警代码       := 0;
    o_b故障               := FALSE;
    s_b初始化完成         := FALSE;
    s_b初始化中           := FALSE;

    (* 清零状态输出 *)
    o_b运行中             := FALSE;
    o_i当前状态           := STP_空闲;

    (* 停止所有定时器 *)
    s_t动作定时器(IN := FALSE);
    s_t通讯超时定时器(IN := FALSE);
    s_t初始化定时器(IN := FALSE);
    s_t抓料保持定时器(IN := FALSE);

    RETURN;  (* 退出功能块, 不执行后续逻辑 *)
END_IF;


(* ============================================================================
 第二部分: 初始化流程 (上电或复位后首次使能时执行)
 ============================================================================ *)
  
IF NOT s_b初始化完成 THEN
    s_b初始化中 := TRUE;

    (* 初始化定时器: 防止初始化卡死 *)
    s_t初始化定时器(IN := TRUE, PT := T_DEF_初始化超时);

    (* 初始化动作:
       1. 所有输出回到安全状态(禁止抓料, 安全区FALSE)
       2. 伺服使能准备(实际使能由主控统一协调)
       3. 状态清零
    *)

    (* 安全输出状态: 禁止抓料, 安全区默认FALSE(保守策略) *)
    o_b允许抓料            := FALSE;
    o_b安全区信号          := FALSE;
    o_bX2轴请求前移       := FALSE;
    o_bX2轴请求后移       := FALSE;

    (* 步序归零 *)
    s_i步序               := STP_空闲;
    s_b故障               := FALSE;
    s_i活跃报警           := 0;

    (* 检查初始化条件:
       X2轴伺服无故障 AND (已在原点 OR 超时强制完成)
       允许在有非关键报警情况下继续, 报警单独处理
    *)
    IF (NOT i_bX2轴_伺服故障) OR s_t初始化定时器.Q THEN
        (* 初始化完成 或 超时强制完成(伺服故障会单独报203号报警) *)
        s_b初始化完成 := TRUE;
        s_b初始化中 := FALSE;
        s_t初始化定时器(IN := FALSE);

        (* 初始化完成后关闭输出(进入空闲态的安全状态) *)
        o_b允许抓料        := FALSE;
        o_b安全区信号      := FALSE;
        o_bX2轴请求前移   := FALSE;
        o_bX2轴请求后移   := FALSE;
    END_IF;

    (* 初始化期间不执行自动/手动逻辑 *)
    o_b运行中 := FALSE;
    o_i当前状态 := STP_空闲;
    RETURN;
END_IF;


(* ============================================================================
 第三部分: 安全区逻辑处理 (所有模式共用, 最高优先级之一)
 ============================================================================ *)

(*--- 安全区核心逻辑 ---
   目的: 防止取放料机构和打胶机同时在工作区域造成碰撞
   原则: 取放料机构优先(它是主动方, 先放料后打胶机才能进入)

   判断依据:
   - i_b取放料_放料完成 = TRUE 表示取放料机构已完成放料并移出工作区
   - 当取放料机构正在工作时(放料完成=FALSE), 安全区应为FALSE
   - 只有当放料完成且确认离开后, 安全区才为TRUE
*)

(*--- 检测取放料机构工作状态的上升沿 ---*)
(* 当放料完成从FALSE变为TRUE时, 说明取放料机构刚完成工作并离开 *)
IF i_b取放料_放料完成 AND NOT s_b上次放料完成 THEN
    (* 放料完成的上升沿: 标记取放料机构曾工作过, 现在已离开 *)
    s_b取放料曾工作 := TRUE;
ELSIF NOT i_b取放料_放料完成 THEN
    (* 放料完成=FALSE: 取放料机构可能正在工作中或尚未开始 *)
    (* 如果之前有过放料完成又变为FALSE, 说明新的一轮开始了 *)
END_IF;

(*--- 更新上次状态(用于下次扫描周期的上升沿检测) ---*)
s_b上次放料完成 := i_b取放料_放料完成;

(*--- 安全区信号输出逻辑 ---*)
IF i_b取放料_放料完成 THEN
    (* 放料完成=TRUE: 取放料机构已离开工作区, 安全区开放 *)
    o_b安全区信号 := TRUE;
ELSE
    (* 放料完成=FALSE: 取放料机构可能还在工作区, 安全区关闭 *)
    o_b安全区信号 := FALSE;
END_IF;


(* ============================================================================
 第四部分: X2轴伺服故障检测 (所有模式共用, 最高优先级)
 ============================================================================ *)

(*--- X2轴伺服故障检测 ---*)
IF i_bX2轴_伺服故障 THEN
    IF s_i活跃报警 <> ALM_X2轴伺服故障 THEN
        (* 新故障: 记录报警 *)
        s_i活跃报警 := ALM_X2轴伺服故障;
        s_b故障 := TRUE;
    END_IF;
    (* 伺服故障时立即停止X2轴运动请求 *)
    s_bX2轴请求前移   := FALSE;
    o_bX2轴请求前移   := FALSE;
    s_bX2轴请求后移   := FALSE;
    o_bX2轴请求后移   := FALSE;
ELSIF s_i活跃报警 = ALM_X2轴伺服故障 THEN
    (* 故障消失且当前只有此报警 -> 清除 *)
    s_i活跃报警 := 0;
    s_b故障 := FALSE;
END_IF;


(* ============================================================================
 第五部分: 模式分发 (自动/手动)
 ============================================================================ *)

IF i_b自动模式 THEN
    (*==========================================================================
      自动模式: 执行6步送料状态机
      =========================================================================*)
    CALL_自动模式状态机();

ELSIF i_b手动模式 THEN
    (*==========================================================================
      手动模式: 执行手动点动控制(X2轴前后点动)
      =========================================================================*)
    CALL_手动模式控制();

ELSE
    (* 无效模式: 停止所有输出, 进入安全状态 *)
    o_b允许抓料            := FALSE;
    o_bX2轴请求前移       := FALSE;
    o_bX2轴请求后移       := FALSE;

    (* 如果不在故障态, 归零步序 *)
    IF NOT s_b故障 THEN
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
    END_IF;
END_IF;


(* ============================================================================
 第六部分: 停止与复位处理
 ============================================================================ *)

(*--- 全局停止: 停止自动循环, 保持当前位置 ---*)
IF i_b停止 THEN
    IF s_b运行中 AND NOT s_b故障 THEN
        (* 停止并复位到空闲 *)
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
        s_b启动触发 := FALSE;

        (* 停止所有输出 *)
        o_b允许抓料            := FALSE;
        o_bX2轴请求前移       := FALSE;
        o_bX2轴请求后移       := FALSE;
        s_bX2轴请求前移       := FALSE;
        s_bX2轴请求后移       := FALSE;

        (* 停止定时器 *)
        s_t动作定时器(IN := FALSE);
        s_t通讯超时定时器(IN := FALSE);
        s_t抓料保持定时器(IN := FALSE);
        s_b等待打胶机响应     := FALSE;
    END_IF;
END_IF;


(*--- 全局复位: 清除所有报警和故障, 重新初始化 ---*)
IF i_b复位 THEN
    IF s_b故障 THEN
        (* 清除报警和故障标志 *)
        s_i活跃报警 := 0;
        s_b故障 := FALSE;
        o_i本站报警代码 := 0;

        (* 归零步序和计数器 *)
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
        s_b启动触发 := FALSE;

        (* 安全输出状态: 全部归零 *)
        o_b允许抓料            := FALSE;
        o_bX2轴请求前移       := FALSE;
        o_bX2轴请求后移       := FALSE;
        s_bX2轴请求前移       := FALSE;
        s_bX2轴请求后移       := FALSE;
        s_bX2轴在待机位       := FALSE;
        s_bX2轴在取料位       := FALSE;

        (* 清零安全区变量 *)
        s_b取放料曾工作      := FALSE;
        s_b等待打胶机响应     := FALSE;

        (* 停止定时器 *)
        s_t动作定时器(IN := FALSE);
        s_t通讯超时定时器(IN := FALSE);
        s_t抓料保持定时器(IN := FALSE);

        (* 要求重新初始化 *)
        s_b初始化完成 := FALSE;
    END_IF;
END_IF;


(* ============================================================================
 第七部分: 状态输出汇总
 ============================================================================ *)

(*--- 运行中标志 ---*)
o_b运行中 := s_b运行中;

(*--- 故障标志 ---*)
o_b故障 := s_b故障;

(*--- 当前状态码 ---*)
IF s_b故障 THEN
    o_i当前状态 := 99;  (* 故障状态显示99 *)
ELSE
    o_i当前状态 := s_i步序;
END_IF;

(*--- 本站报警代码 ---*)
o_i本站报警代码 := s_i活跃报警;


(*==============================================================================
 子程序: 自动模式状态机 (6步完整送料循环)
   核心工艺: 等待放料完成 -> X2轴移动到取料位 -> 等待允许 -> 抓料 -> 返回待机
   安全约束: 步骤1需要安全区信号为TRUE才能继续
  ==============================================================================*)
METHOD CALL_自动模式状态机 : VOID

    (*--- 故障时不执行状态机 ---*)
    IF s_b故障 THEN
        s_b运行中 := FALSE;
        (* 故障安全输出: 全部停止 *)
        o_b允许抓料            := FALSE;
        o_bX2轴请求前移       := FALSE;
        o_bX2轴请求后移       := FALSE;
        s_bX2轴请求前移       := FALSE;
        s_bX2轴请求后移       := FALSE;
        s_t动作定时器(IN := FALSE);
        s_t通讯超时定时器(IN := FALSE);
        s_t抓料保持定时器(IN := FALSE);
        s_b等待打胶机响应     := FALSE;
        RETURN;
    END_IF;

    (*--- 启动触发检测 (上升沿) ---*)
    IF i_b启动 AND NOT s_b启动触发 THEN
        s_b启动触发 := TRUE;
    END_IF;

    (*--- 单例状态机 (全局唯一, 因为只有一个打胶机送料机构) ---*)
    CASE s_i步序 OF

    (*======================================================================
     步骤0: 空闲/待机位置
     等待启动触发, 收到启动后进入等待放料完成
     ======================================================================*)
    STP_空闲:
        s_b运行中 := FALSE;
        (* 安全输出状态: 全部归零 *)
        o_b允许抓料            := FALSE;
        o_bX2轴请求前移       := FALSE;
        o_bX2轴请求后移       := FALSE;
        s_bX2轴请求前移       := FALSE;
        s_bX2轴请求后移       := FALSE;
        s_b等待打胶机响应     := FALSE;

        (* 启动条件: 收到启动触发 *)
        IF s_b启动触发 THEN
            s_i步序 := STP_等待放料完成;
            s_b运行中 := TRUE;
        END_IF;

    (*======================================================================
     步骤1: 等待取放料放料完成
     等待取放料机构的放料完成信号(即安全区开放)
     条件: i_b取放料_放料完成 = TRUE
     ======================================================================*)
    STP_等待放料完成:
        (* 保持安全输出状态 *)
        o_b允许抓料            := FALSE;
        o_bX2轴请求前移       := FALSE;
        o_bX2轴请求后移       := FALSE;
        s_bX2轴请求前移       := FALSE;
        s_bX2轴_request后移       := FALSE;

        (* 等待条件: 取放料机构放料完成(安全区开放) *)
        IF i_b取放料_放料完成 THEN
            (* 放料完成, 可以开始移动到取料位置 *)
            s_i步序 := STP_移动到取料位置;
            (* 启动移动超时定时器 *)
            s_t动作定时器(IN := TRUE, PT := T_DEF_移动超时时间);
            (* 请求X2轴向前移动(去打胶机取料位置) *)
            s_bX2轴_request前移   := TRUE;
            o_bX2轴_request前移   := TRUE;
            s_bX2轴_request后移   := FALSE;
            o_bX2轴_request后移   := FALSE;
            s_bX2轴在待机位   := FALSE;
        END_IF;

        (* 注意: 此步骤没有独立的超时报警, 因为等待上游信号是正常行为
           超时保护由公共层或操作员手动停止处理 *)

    (*======================================================================
     步骤2: 移动到打胶机取料位置 (X2轴水平移动)
     X2轴向前移动到打胶机取料口位置
     等待X2轴到达取料位置或超时
     注: X2轴的实际脉冲输出由主控根据请求标志处理
     ======================================================================*)
    STP_移动到取料位置:
        (* 保持X2轴前移请求 *)
        s_bX2轴_request前移   := TRUE;
        o_bX2轴_request前移   := TRUE;
        s_bX2轴_request后移   := FALSE;
        o_bX2轴_request后移   := FALSE;

        (* 到达取料位置的判断:
           由主控在X2轴到达目标位置后置位s_bX2轴在取料位
           或通过位置判断(i_rX2轴当前位置接近i_r取料位置)
        *)
        IF s_bX2轴在取料位 THEN
            (* 到达取料位置, 转入等待打胶机允许送料 *)
            s_t动作定时器(IN := FALSE);
            s_bX2轴_request前移   := FALSE;
            o_bX2轴_request前移   := FALSE;
            s_bX2轴在取料位   := TRUE;
            s_i步序 := STP_等待允许送料;
            (* 启动通讯超时定时器(等待打胶机响应) *)
            s_t通讯超时定时器(IN := TRUE, PT := T_DEF_通讯超时时间);
            s_b等待打胶机响应 := TRUE;
        ELSIF s_t动作定时器.Q THEN
            (* 超时: X2轴未在规定时间内到达取料位置 *)
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_X2轴移动超时;
            s_b故障 := TRUE;
            s_bX2轴_request前移   := FALSE;
            o_bX2轴_request前移   := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
            s_b等待打胶机响应 := FALSE;
        END_IF;

    (*======================================================================
     步骤3: 等待打胶机允许送料
     等待打胶机发出允许送料信号(i_b打胶机允许送料=TRUE)
     同时监控通讯超时
     ======================================================================*)
    STP_等待允许送料:
        (* 保持当前状态, 等待打胶机响应 *)
        s_bX2轴_request前移   := FALSE;
        o_bX2轴_request前移   := FALSE;
        s_bX2轴_request后移   := FALSE;
        o_bX2轴_request后移   := FALSE;
        o_b允许抓料        := FALSE;

        (* 检查打胶机允许送料信号 *)
        IF i_b打胶机允许送料 THEN
            (* 打胶机允许送料, 转入发送允许抓料步骤 *)
            s_t通讯超时定时器(IN := FALSE);
            s_b等待打胶机响应 := FALSE;
            s_i步序 := STP_发送允许抓料;
            (* 启动抓料保持定时器和通讯超时定时器(等待取料完成) *)
            s_t抓料保持定时器(IN := TRUE, PT := T_DEF_抓料保持时间);
            s_t通讯超时定时器(IN := TRUE, PT := T_DEF_通讯超时时间);
            s_b等待打胶机响应 := TRUE;
            (* 发送允许抓料信号 *)
            o_b允许抓料 := TRUE;
        ELSIF s_t通讯超时定时器.Q THEN
            (* 超时: 打胶机长时间无响应 *)
            s_t通讯超时定时器(IN := FALSE);
            s_i活跃报警 := ALM_通讯超时;
            s_b故障 := TRUE;
            o_b允许抓料 := FALSE;
            s_b等待打胶机响应 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤4: 发送允许抓料 + 等待打胶机取料完成
     保持允许抓料信号, 等待打胶机完成取料动作
     ======================================================================*)
    STP_发送允许抓料:
        (* 保持允许抓料输出 *)
        o_b允许抓料 := TRUE;
        s_bX2轴_request前移 := FALSE;
        o_bX2轴_request前移 := FALSE;
        s_bX2轴_request后移 := FALSE;
        o_bX2轴_request后移 := FALSE;

        (* 检查打胶机取料完成信号 *)
        IF i_b打胶机取料完成 THEN
            (* 打胶机取料完成, 转入返回待机位置 *)
            s_t通讯超时定时器(IN := FALSE);
            s_t抓料保持定时器(IN := FALSE);
            s_b等待打胶机响应 := FALSE;
            (* 保持一段时间的允许抓料信号后关闭 *)
            (* 或者立即关闭, 根据实际工艺需求 *)
            o_b允许抓料 := FALSE;
            s_i步序 := STP_返回待机位置;
            (* 启动返回移动定时器 *)
            s_t动作定时器(IN := TRUE, PT := T_DEF_移动超时时间);
            (* 请求X2轴向后移动(返回待机位置) *)
            s_bX2轴_request前移   := FALSE;
            o_bX2轴_request前移   := FALSE;
            s_bX2轴_request后移   := TRUE;
            o_bX2轴_request后移   := TRUE;
            s_bX2轴在取料位   := FALSE;
        ELSIF s_t通讯超时定时器.Q THEN
            (* 超时: 打胶机取料超时 *)
            s_t通讯超时定时器(IN := FALSE);
            s_t抓料保持定时器(IN := FALSE);
            s_i活跃报警 := ALM_通讯超时;
            s_b故障 := TRUE;
            o_b允许抓料 := FALSE;
            s_b等待打胶机响应 := FALSE;
            s_bX2轴_request后移 := FALSE;
            o_bX2轴_request后移 := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    (*======================================================================
     步骤5: 返回待机位置 (X2轴水平移动回待机位)
     X2轴向后移动回到待机位置(安全等待位置)
     等待X2轴到达待机位置或超时
     完成后回到步骤1, 继续下一轮循环
     ======================================================================*)
    STP_返回待机位置:
        (* 保持X2轴后移请求 *)
        s_bX2轴_request前移   := FALSE;
        o_bX2轴_request前移   := FALSE;
        s_bX2轴_request后移   := TRUE;
        o_bX2轴_request后移   := TRUE;

        (* 到达待机位置的判断:
           由主控在X2轴到达目标位置后置位s_bX2轴在待机位
           或通过位置判断(i_rX2轴当前位置接近i_r待机位置)
        *)
        IF s_bX2轴在待机位 THEN
            (* 到达待机位置, 完成一轮循环, 回到等待放料完成 *)
            s_t动作定时器(IN := FALSE);
            s_bX2轴_request后移   := FALSE;
            o_bX2轴_request后移   := FALSE;
            s_bX2轴在待机位   := TRUE;
            s_i步序 := STP_等待放料完成;  (* 回到步骤1, 继续循环 *)
            (* 不重置s_b启动触发, 保持连续循环 *)
        ELSIF s_t动作定时器.Q THEN
            (* 超时: X2轴未在规定时间内返回待机位置 *)
            s_t动作定时器(IN := FALSE);
            s_i活跃报警 := ALM_X2轴移动超时;
            s_b故障 := TRUE;
            s_bX2轴_request后移   := FALSE;
            o_bX2轴_request后移   := FALSE;
            s_i步序 := STP_空闲;
            s_b运行中 := FALSE;
            s_b启动触发 := FALSE;
        END_IF;

    ELSE
        (* 无效步序: 强制归零 *)
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;

    END_CASE;


(*==============================================================================
 子程序: 手动模式控制 (X2轴点动前/后, 带互锁和安全限制)
  ==============================================================================*)
METHOD CALL_手动模式控制 : VOID

    (*--- 故障时禁止手动操作 ---*)
    IF s_b故障 THEN
        s_b手动允许 := FALSE;
        o_b允许抓料            := FALSE;
        s_bX2轴_request前移       := FALSE;
        s_bX2轴_request后移       := FALSE;
        s_i步序 := STP_空闲;
        s_b运行中 := FALSE;
        RETURN;
    END_IF;

    s_b手动允许 := TRUE;
    s_b运行中 := FALSE;
    s_i步序 := STP_空闲;  (* 手动模式下步序显示为空闲 *)
    o_b允许抓料 := FALSE;   (* 手动模式下不允许自动抓料 *)

    (*======================================================================
     手动操作 - X2轴伺服点动控制 (前/后互锁)
     注意: 伺服的点动脉冲输出由主控根据请求标志处理
     本功能块只输出请求标志
     ======================================================================*)

    (*--- X2轴点动: 前/后互锁 ---*)
    IF i_bX2轴点动前 AND NOT i_bX2轴点动后 THEN
        (* X2轴向前点动(去打胶机取料位置方向) *)
        (* 检查是否已到正向限位 *)
        IF NOT i_bX2轴_正向限位 THEN
            s_bX2轴_request前移 := TRUE;
            o_bX2轴_request前移 := TRUE;
            s_bX2轴_request后移 := FALSE;
            o_bX2轴_request后移 := FALSE;
        END_IF;
    ELSIF i_bX2轴点动后 AND NOT i_bX2轴点动前 THEN
        (* X2轴向后点动(返回待机位置方向) *)
        (* 检查是否已到反向限位 *)
        IF NOT i_bX2轴_反向限位 THEN
            s_bX2轴_request后移 := TRUE;
            o_bX2轴_request后移 := TRUE;
            s_bX2轴_request前移 := FALSE;
            o_bX2轴_request前移 := FALSE;
        END_IF;
    ELSE
        (* 无X2轴点动操作 *)
        s_bX2轴_request前移 := FALSE;
        o_bX2轴_request前移 := FALSE;
        s_bX2轴_request后移 := FALSE;
        o_bX2轴_request后移 := FALSE;
    END_IF;


END_FUNCTION_BLOCK

(* ============================================================================
 程序结束
 ============================================================================ *)
