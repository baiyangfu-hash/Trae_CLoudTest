(* ================================================================= *)
(*  功能块名称：FB_外部设备交互                                      *)
(*  功能描述：处理与组框机、打胶机和机器人的交互逻辑                 *)
(*  创建日期：2026-04-27                                            *)
(*  版本号：V4.1.0                                                  *)
(*  基于版本：V4.0.0                                                *)
(*  编制人：[待填写]                                                *)
(*  审核人：[待填写]                                                *)
(*                                                                  *)
(*  遵循规范：                                                      *)
(*    - 801_PLC变量命名与功能块命名规范_DEV-V1.0.5                  *)
(*    - 810_PLC编程规范_DEV-V1.0.3                                  *)
(*                                                                  *)
(*  变更记录：                                                        *)
(* ---------------------------------------------------------------- *)
(*  V4.1.0 (2026-04-27) Trae                                      *)
(*  - 新增: 外部设备交互功能块, 处理组框机、打胶机和机器人交互        *)
(*  - 新增: 支持机器人上边框功能, 包含码料逻辑                       *)
(*  - 优化: 统一外部设备报警管理                                     *)
(* ---------------------------------------------------------------- *)
(*  V4.0.0 (2026-04-23) 初始版本                                   *)
(*                                                                  *)
(*  详细说明:                                                        *)
(*    外部设备交互功能块负责处理与外部设备的所有交互逻辑:            *)
(*    1. 组框机交互: 接收组框机信号, 发送控制信号                    *)
(*    2. 打胶机交互: 接收打胶机信号, 发送控制信号                    *)
(*    3. 机器人交互: 接收机器人信号, 发送控制信号 (预留)            *)
(*    4. 安全联锁: 处理外部设备的安全联锁逻辑                        *)
(*    5. 报警管理: 汇总外部设备报警信息                              *)
(*                                                                  *)
(*  架构特点:                                                        *)
(*    - 纯逻辑块: 无物理地址依赖, 所有输入/输出均为逻辑变量          *)
(*    - 高内聚: 集中处理所有外部设备交互逻辑                        *)
(*    - 低耦合: 与主控程序通过明确的接口交互                        *)
(*    - 可扩展: 预留机器人接口, 支持未来功能扩展                    *)
(* ================================================================= *)

FUNCTION_BLOCK FB_外部设备交互

//#region 100_VAR_INPUT 输入变量定义
VAR_INPUT
    //#region 110_系统控制信号 来自主控HMI公共透传
    (* ========================================================================== *)
    (* 一、系统控制信号                                                          *)
    (* ========================================================================== *)
    i_b使能               : BOOL;   // 系统总使能
    i_b自动模式           : BOOL;   // 自动模式选择
    i_b手动模式           : BOOL;   // 手动模式选择
    i_b启动               : BOOL;   // 启动按钮
    i_b停止               : BOOL;   // 停止按钮
    i_b复位               : BOOL;   // 复位按钮
    //#endregion 110_系统控制信号
    
    //#region 120_组框机输入信号 来自组框机
    (* ========================================================================== *)
    (* 二、组框机输入信号                                                        *)
    (* ========================================================================== *)
    i_b组框机_自动中      : BOOL;   // 组框机自动运行中
    i_b组框机_允许送料    : BOOL;   // 组框机允许向缓存机输送边框
    i_b组框机_有料请求    : BOOL;   // 组框机有边框需要送入缓存机
    i_b组框机_开门请求    : BOOL;   // 组框机操作门打开(需本机暂停)
    i_b组框机_急停        : BOOL;   // 组框机急停信号(需联锁)
    i_b组框机_安全异常    : BOOL;   // 组框机安全系统异常
    i_b组框机_通讯异常    : BOOL;   // 与组框机通讯异常
    //#endregion 120_组框机输入信号
    
    //#region 130_打胶机输入信号 来自打胶机
    (* ========================================================================== *)
    (* 三、打胶机输入信号                                                        *)
    (* ========================================================================== *)
    i_b打胶机_自动中      : BOOL;   // 打胶机自动运行中
    i_b打胶机_允许送料    : BOOL;   // 打胶机准备好可接收边框
    i_b打胶机_取料完成    : BOOL;   // 打胶机已完成边框抓取
    i_b打胶机_故障        : BOOL;   // 打胶机设备故障报警
    i_b打胶机_急停        : BOOL;   // 打胶机急停状态
    i_b打胶机_通讯异常    : BOOL;   // 与打胶机通讯中断
    //#endregion 130_打胶机输入信号
    
    //#region 140_机器人输入信号 来自机器人(预留)
    (* ========================================================================== *)
    (* 四、机器人输入信号 (预留)                                                *)
    (* ========================================================================== *)
    i_b机器人_自动中      : BOOL;   // 机器人自动运行中
    i_b机器人_码料完成    : BOOL;   // 机器人完成码料
    i_b机器人_故障        : BOOL;   // 机器人设备故障
    i_b机器人_急停        : BOOL;   // 机器人急停状态
    i_b机器人_通讯异常    : BOOL;   // 与机器人通讯异常
    //#endregion 140_机器人输入信号
    
    //#region 150_本机状态信号 来自主控
    (* ========================================================================== *)
    (* 五、本机状态信号                                                          *)
    (* ========================================================================== *)
    i_b本机就绪          : BOOL;   // 本机就绪状态
    i_b任何报警激活      : BOOL;   // 本机有任何报警激活
    i_b系统故障          : BOOL;   // 本机系统故障
    //#endregion 150_本机状态信号
END_VAR
//#endregion 100_VAR_INPUT

//#region 200_VAR_OUTPUT 输出变量定义
VAR_OUTPUT
    //#region 210_组框机输出信号 输出到组框机
    (* ========================================================================== *)
    (* 六、组框机输出信号                                                        *)
    (* ========================================================================== *)
    q_b组框机_请求送料    : BOOL;   // 向组框机请求输送边框
    q_b组框机_暂停          : BOOL;   // 向组框机发送暂停指令
    q_b组框机_急停          : BOOL;   // 向组框机发送急停联锁信号
    q_b申请开门             : BOOL;   // 向组框机申请开门操作
    q_b组框机_就绪          : BOOL;   // 本机就绪, 可接收边框
    //#endregion 210_组框机输出信号
    
    //#region 220_打胶机输出信号 输出到打胶机
    (* ========================================================================== *)
    (* 七、打胶机输出信号                                                        *)
    (* ========================================================================== *)
    q_b打胶机_请求运行    : BOOL;   // 请求打胶机启动运行
    q_b允许抓料            : BOOL;   // 通知打胶机可以抓取边框
    q_b安全区信号          : BOOL;   // 安全区开放/关闭信号
    q_b打胶机_复位请求    : BOOL;   // 向打胶机发送复位请求
    //#endregion 220_打胶机输出信号
    
    //#region 230_机器人输出信号 输出到机器人(预留)
    (* ========================================================================== *)
    (* 八、机器人输出信号 (预留)                                                *)
    (* ========================================================================== *)
    q_b机器人_允许码料    : BOOL;   // 允许机器人进行码料
    q_b机器人_停止码料    : BOOL;   // 停止机器人码料
    q_b机器人_复位请求    : BOOL;   // 向机器人发送复位请求
    //#endregion 230_机器人输出信号
    
    //#region 240_状态与报警输出 输出到主控
    (* ========================================================================== *)
    (* 九、状态与报警输出                                                        *)
    (* ========================================================================== *)
    q_b组框机紧急停止      : BOOL;   // 组框机急停/安全异常时强制本机停止
    q_b外部设备故障        : BOOL;   // 外部设备故障标志
    q_i外部设备报警汇总   : INT;    // 外部设备故障报警码(300~399段)
    q_b系统安全条件满足    : BOOL;   // 系统安全条件是否满足
    //#endregion 240_状态与报警输出
END_VAR
//#endregion 200_VAR_OUTPUT

//#region 300_VAR 内部变量定义
VAR
    (* ========================================================================== *)
    (* 十、内部变量                                                              *)
    (* ========================================================================== *)
    b安全条件满足        : BOOL;   // 内部安全条件满足标志
    i外部设备报警码      : INT;    // 内部报警码变量
END_VAR
//#endregion 300_VAR

//#region 500_功能块执行体
(* ========================================================================== *)
(* 功能块执行体                                                                *)
(* ========================================================================== *)

//#region 510_打胶机信号处理
(* -------------------------------------------------------------------------- *)
(* 1. 打胶机信号有效性检查与安全回退                                         *)
(* -------------------------------------------------------------------------- *)
IF i_b打胶机_通讯异常 THEN
    // 当通讯异常时, 强制将关键输入信号置为保守值(禁止状态)
    // 注意: 这里是在功能块内部处理, 实际输入值不会被修改
    // 后续逻辑会基于保守值处理
    q_b允许抓料       := FALSE;     // 强制禁止抓料输出
    q_b安全区信号     := FALSE;     // 强制关闭安全区
ELSE
    // 正常情况下, 安全区信号根据系统状态控制
    q_b安全区信号     := i_b使能 AND i_b自动模式;
END_IF;

(* -------------------------------------------------------------------------- *)
(* 5. 打胶机主动控制信号生成                                                  *)
(* -------------------------------------------------------------------------- *)
// 请求运行: 本机自动启动且打胶机未在自动运行中
IF i_b自动模式 AND i_b使能 AND NOT i_b打胶机_自动中 THEN
    q_b打胶机_请求运行 := TRUE;
ELSE
    q_b打胶机_请求运行 := FALSE;
END_IF;

// 复位请求: 本机复位且打胶机有故障或急停
IF i_b复位 AND (i_b打胶机_故障 OR i_b打胶机_急停) THEN
    q_b打胶机_复位请求 := TRUE;
ELSE
    q_b打胶机_复位请求 := FALSE;
END_IF;

// 允许抓料: 打胶机允许送料且本机就绪
IF i_b打胶机_允许送料 AND i_b本机就绪 THEN
    q_b允许抓料 := TRUE;
ELSE
    q_b允许抓料 := FALSE;
END_IF;
//#endregion 510_打胶机信号处理

//#region 520_组框机信号处理
(* -------------------------------------------------------------------------- *)
(* 2. 组框机安全联锁处理                                                      *)
(* -------------------------------------------------------------------------- *)
// 组框机急停/安全异常 -> 本机必须立即停止 + 回传确认
IF i_b组框机_急停 OR i_b组框机_安全异常 THEN
    q_b组框机_急停 := TRUE;          // 向组框机回传急停确认
    q_b组框机紧急停止 := TRUE;         // 设置本机停止标志(传给各工站)
ELSE
    q_b组框机_急停 := FALSE;
    q_b组框机紧急停止 := FALSE;
END_IF;

// 组框机开门请求 -> 本机需暂停运行 (互锁)
IF i_b组框机_开门请求 THEN
    q_b组框机_暂停 := TRUE;          // 通知组框机本机已暂停
    q_b申请开门    := TRUE;          // 向组框机确认可以开门
ELSE
    q_b组框机_暂停 := FALSE;
    q_b申请开门    := FALSE;
END_IF;

(* -------------------------------------------------------------------------- *)
(* 3. 本机就绪信号生成                                                        *)
(* -------------------------------------------------------------------------- *)
// 就绪 = 自动模式 AND 系统使能 AND 无报警 AND 非紧急停止
q_b组框机_就绪 := i_b自动模式
                   AND i_b使能
                   AND (NOT i_b任何报警激活)
                   AND (NOT q_b组框机紧急停止);

(* -------------------------------------------------------------------------- *)
(* 4. 送料请求协调逻辑                                                        *)
(* -------------------------------------------------------------------------- *)
// 当本机需要边框且就绪且上游允许时, 请求送料
IF i_b使能
   AND (NOT q_b组框机紧急停止)         // 无紧急停止
   AND i_b组框机_允许送料             // 上游允许送出
   AND i_b自动模式                  // 自动模式下才请求
THEN
    q_b组框机_请求送料 := TRUE;
ELSE
    q_b组框机_请求送料 := FALSE;
END_IF;
//#endregion 520_组框机信号处理

//#region 530_机器人信号处理
(* -------------------------------------------------------------------------- *)
(* 6. 机器人控制逻辑 (预留)                                                   *)
(* -------------------------------------------------------------------------- *)
// 允许码料: 本机就绪且无报警
IF i_b本机就绪 AND (NOT i_b任何报警激活) THEN
    q_b机器人_允许码料 := TRUE;
ELSE
    q_b机器人_允许码料 := FALSE;
END_IF;

// 停止码料: 系统故障或急停
IF i_b系统故障 OR i_b组框机_急停 OR i_b打胶机_急停 OR i_b机器人_急停 THEN
    q_b机器人_停止码料 := TRUE;
ELSE
    q_b机器人_停止码料 := FALSE;
END_IF;

// 机器人复位请求
IF i_b复位 AND (i_b机器人_故障 OR i_b机器人_急停) THEN
    q_b机器人_复位请求 := TRUE;
ELSE
    q_b机器人_复位请求 := FALSE;
END_IF;
//#endregion 530_机器人信号处理

//#region 540_报警管理
(* -------------------------------------------------------------------------- *)
(* 7. 外部设备报警码汇总                                                      *)
(* -------------------------------------------------------------------------- *)
// 将外部设备故障统一编码, 传入公共报警FB的扩展通道
IF i_b打胶机_故障 THEN
    i外部设备报警码 := 300;        // 300=打胶机设备故障
ELSIF i_b打胶机_急停 THEN
    i外部设备报警码 := 301;        // 301=打胶机急停
ELSIF i_b打胶机_通讯异常 THEN
    i外部设备报警码 := 302;        // 302=打胶机通讯异常
ELSIF i_b组框机_急停 THEN
    i外部设备报警码 := 310;        // 310=组框机急停
ELSIF i_b组框机_安全异常 THEN
    i外部设备报警码 := 311;        // 311=组框机安全系统异常
ELSIF i_b组框机_通讯异常 THEN
    i外部设备报警码 := 312;        // 312=组框机通讯异常
ELSIF i_b机器人_故障 THEN
    i外部设备报警码 := 320;        // 320=机器人设备故障
ELSIF i_b机器人_急停 THEN
    i外部设备报警码 := 321;        // 321=机器人急停
ELSIF i_b机器人_通讯异常 THEN
    i外部设备报警码 := 322;        // 322=机器人通讯异常
ELSE
    i外部设备报警码 := 0;           // 0=无外部设备报警
END_IF;

q_i外部设备报警汇总 := i外部设备报警码;
q_b外部设备故障 := (i外部设备报警码 <> 0);
//#endregion 540_报警管理

//#region 550_安全条件计算
(* -------------------------------------------------------------------------- *)
(* 8. 安全条件计算                                                            *)
(* -------------------------------------------------------------------------- *)
(* 安全条件检查:
   1. 组框机无急停
   2. 打胶机无急停且无故障
   3. 机器人无急停且无故障 (预留)
*)
IF NOT i_b组框机_急停              // 组框机急停联锁
   AND NOT i_b打胶机_急停           // 打胶机急停联锁
   AND NOT i_b打胶机_故障            // 打胶机故障联锁
   AND NOT i_b机器人_急停            // 机器人急停联锁(预留)
   AND NOT i_b机器人_故障            // 机器人故障联锁(预留)
THEN
    b安全条件满足 := TRUE;
ELSE
    b安全条件满足 := FALSE;
END_IF;

q_b系统安全条件满足 := b安全条件满足;
//#endregion 550_安全条件计算
//#endregion 500_功能块执行体

END_FUNCTION_BLOCK